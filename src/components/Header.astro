---
import { getAllCategories, getSiteSettings } from '../lib/keystatic-reader';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const settings = await getSiteSettings();
const allCategories = await getAllCategories();
const parentCategories = allCategories.filter((cat) => !cat.entry.parentCategory);
const categoryTree = parentCategories.map((parent) => ({
  ...parent,
  children: allCategories.filter((cat) => cat.entry.parentCategory === parent.slug),
}));
---

<header class="bg-white border-b border-neutral-200 sticky top-0 z-50 antialiased font-sans">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Top Row: search | LOGO | about -->
    <div class="flex items-center justify-between py-5 border-b border-neutral-100">
      <!-- Left Search Anchor -->
      <div class="hidden md:flex items-center gap-4 w-40">
        <a href="/search" class="p-1 text-neutral-600 hover:text-black transition duration-200" aria-label="Search">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </a>
      </div>

      <!-- Centered Premium Logo -->
      <a href="/" class="flex-1 text-center no-underline">
        {settings.logoImage ? (
          <img src={settings.logoImage} alt={settings.siteName} class="h-8 mx-auto" />
        ) : (
          <span class="text-xl font-serif tracking-[0.25em] uppercase text-neutral-950 hover:opacity-80 transition duration-200">
            {settings.siteName}
          </span>
        )}
      </a>

      <!-- Right Nav Anchors -->
      <div class="hidden md:flex items-center justify-end gap-6 w-40">
        <a href="/about" class="text-[10px] tracking-widest uppercase font-semibold text-neutral-500 hover:text-neutral-950 transition duration-200">About</a>
        <a href="/contact" class="text-[10px] tracking-widest uppercase font-semibold text-neutral-500 hover:text-neutral-950 transition duration-200">Contact</a>
      </div>

      <!-- Mobile hamburger navigation button -->
      <button id="mobile-menu-button" class="md:hidden p-2 text-neutral-700 hover:bg-neutral-50 transition" aria-label="Menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Category Nav Links Row Layout -->
    <div class="hidden md:flex items-center justify-center gap-8 py-3.5">
      <a href="/" class={`text-[11px] tracking-widest uppercase font-bold transition duration-200 pb-0.5 ${currentPath === '/' ? 'text-neutral-950 border-b-2 border-neutral-950' : 'text-neutral-500 hover:text-neutral-950'}`}>
        Home
      </a>

      {categoryTree.map((parent) => (
        <div class="relative group">
          <a
            href={`/category/${parent.slug}/`}
            class={`flex items-center gap-1 text-[11px] tracking-widest uppercase font-bold transition duration-200 pb-0.5 ${currentPath === `/category/${parent.slug}` ? 'text-neutral-950 border-b-2 border-neutral-950' : 'text-neutral-500 hover:text-neutral-950'}`}>
            {parent.entry.name}
            {parent.children.length > 0 && (
              <svg class="w-3 h-3 text-neutral-400 group-hover:text-neutral-950 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>

          {parent.children.length > 0 && (
            <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 absolute left-1/2 -translate-x-1/2 top-full pt-3 transition-all duration-300 z-50">
              <div class="bg-white border border-neutral-200 shadow-2xl py-2 min-w-[210px] rounded-sm">
                
                {/* ❌ REMOVED: Parent Category Title text block has been cleaned up from here */}
                
                {parent.children.slice(0, 5).map((child) => (
                  <a
                    href={`/category/${child.slug}/`}
                    class="block px-5 py-2.5 text-[11px] tracking-wider uppercase text-neutral-600 hover:bg-neutral-50 hover:text-neutral-950 font-medium transition duration-150">
                    {child.entry.name}
                  </a>
                ))}

                {/* ✅ DYNAMIC LOGIC: Show "View All" panel only if subcategories exceed 5 items */}
                {parent.children.length > 5 && (
                  <div class="border-t border-neutral-100 mt-1 pt-1">
                    <a href={`/category/${parent.slug}/`} class="block px-5 py-2 text-[10px] font-bold uppercase tracking-widest text-[#bba15c] hover:bg-neutral-50 transition duration-150">
                      View All →
                    </a>
                  </div>
                )}
              </div>
            </div>
          )}
        </div>
      ))}
    </div>

  </div>

  <!-- Mobile Menu Panels Drawer -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-neutral-200 bg-white">
    <div class="max-w-7xl mx-auto px-6 py-4 space-y-1">
      <a href="/" class="block py-2 text-xs font-bold uppercase tracking-wider text-neutral-700 hover:text-neutral-950 transition">Home</a>

      {categoryTree.map((parent) => (
        <div class="mobile-category-group">
          <div class="flex items-center justify-between">
            <a href={`/category/${parent.slug}/`} class="block py-2 text-xs font-bold uppercase tracking-wider text-neutral-700 hover:text-neutral-950 transition flex-1">
              {parent.entry.name}
            </a>
            {parent.children.length > 0 && (
              <button class="mobile-category-toggle p-2 text-neutral-400" aria-label="Expand">
                <svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            )}
          </div>
          {parent.children.length > 0 && (
            <div class="mobile-category-children hidden pl-4 border-l border-neutral-100 ml-1">
              {parent.children.map((child) => (
                <a href={`/category/${child.slug}/`} class="block py-2 text-xs text-neutral-500 hover:text-neutral-950 transition">
                  {child.entry.name}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}

      <div class="border-t border-neutral-100 my-2 pt-2">
        <a href="/about" class="block py-2 text-xs font-bold uppercase tracking-wider text-neutral-500 hover:text-neutral-950 transition">About</a>
        <a href="/contact" class="block py-2 text-xs font-bold uppercase tracking-wider text-neutral-500 hover:text-neutral-950 transition">Contact</a>
      </div>
    </div>
  </div>
</header>

<script>
  document.getElementById('mobile-menu-button')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-category-toggle').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const group = btn.closest('.mobile-category-group');
      group?.querySelector('.mobile-category-children')?.classList.toggle('hidden');
      btn.querySelector('svg')?.classList.toggle('rotate-180');
    });
  });
</script>
