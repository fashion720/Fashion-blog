---
import { getAllCategories } from '../lib/keystatic-reader';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const allCategories = await getAllCategories();
const parentCategories = allCategories.filter((cat) => !cat.entry.parentCategory);
const categoryTree = parentCategories.map((parent) => ({
  ...parent,
  children: allCategories.filter((cat) => cat.entry.parentCategory === parent.slug),
}));
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <nav class="container mx-auto px-4 py-4">
    <div class="flex items-center justify-between">
      <a href="/" class="text-2xl font-bold text-gray-900 hover:text-gray-700 transition">Fashion Blog</a>
      
      <div class="hidden md:flex items-center gap-8">
        <a 
          href="/"
          class={`text-gray-700 hover:text-gray-900 transition ${currentPath === '/' ? 'font-semibold text-gray-900' : ''}`}>
          Home
        </a>

        {categoryTree.map((parent) => (
          <div class="relative group">
            <a 
              href={`/category/${parent.slug}/`}
              class={`flex items-center gap-1 text-gray-700 hover:text-gray-900 transition py-2 ${currentPath === `/category/${parent.slug}` ? 'font-semibold text-gray-900' : ''}`}>
              {parent.entry.name}
              {parent.children.length > 0 && (
                <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            
            {parent.children.length > 0 && (
              <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 translate-y-1 group-hover:translate-y-0 absolute left-1/2 -translate-x-1/2 top-full pt-2 transition-all duration-200 z-50">
                <div class="bg-white border border-gray-200 rounded-xl shadow-xl py-3 min-w-[220px] overflow-hidden">
                  <p class="px-4 pb-2 text-[11px] font-semibold uppercase tracking-wider text-gray-400">{parent.entry.name}</p>
                  {parent.children.map((child) => (
                    <a 
                      href={`/category/${child.slug}/`}
                      class="block px-4 py-2.5 text-sm text-gray-700 capitalize hover:bg-gray-50 hover:text-black hover:pl-5 transition-all">
                      {child.entry.name}
                    </a>
                  ))}
                  <div class="border-t border-gray-100 mt-2 pt-2">
                    <a 
                      href={`/category/${parent.slug}/`}
                      class="block px-4 py-2 text-sm font-medium text-gray-900 hover:bg-gray-50 transition">
                      View All {parent.entry.name} →
                    </a>
                  </div>
                </div>
              </div>
            )}
          </div>
        ))}

        <a 
          href="/about"
          class={`text-gray-700 hover:text-gray-900 transition ${currentPath === '/about' ? 'font-semibold text-gray-900' : ''}`}>
          About
        </a>
        <a 
          href="/contact"
          class={`text-gray-700 hover:text-gray-900 transition ${currentPath === '/contact' ? 'font-semibold text-gray-900' : ''}`}>
          Contact
        </a>
      </div>

      <a 
        href="/search"
        class="hidden md:block p-2 hover:bg-gray-100 rounded-lg transition"
        aria-label="Search">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </a>

      <button
        id="mobile-menu-button"
        class="md:hidden p-2 hover:bg-gray-100 rounded-lg transition"
        aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4">
      <a href="/" class="block py-2 text-gray-700 hover:text-gray-900 transition">Home</a>

      {categoryTree.map((parent) => (
        <div class="mobile-category-group">
          <div class="flex items-center justify-between">
            <a href={`/category/${parent.slug}/`} class="block py-2 text-gray-700 hover:text-gray-900 transition flex-1">
              {parent.entry.name}
            </a>
            {parent.children.length > 0 && (
              <button class="mobile-category-toggle p-2 text-gray-500" aria-label="Expand">
                <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            )}
          </div>
          {parent.children.length > 0 && (
            <div class="mobile-category-children hidden pl-4">
              {parent.children.map((child) => (
                <a href={`/category/${child.slug}/`} class="block py-2 text-sm text-gray-600 hover:text-gray-900 transition">
                  {child.entry.name}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}

      <a href="/about" class="block py-2 text-gray-700 hover:text-gray-900 transition">About</a>
      <a href="/contact" class="block py-2 text-gray-700 hover:text-gray-900 transition">Contact</a>
    </div>
  </nav>
</header>

<script>
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  menuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-category-toggle').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const group = btn.closest('.mobile-category-group');
      const children = group?.querySelector('.mobile-category-children');
      const icon = btn.querySelector('svg');
      children?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
