---
import { getAllCategories, getSiteSettings } from '../lib/keystatic-reader';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const settings = await getSiteSettings();
const allCategories = await getAllCategories() || [];

// ⚡ SAFE & ROBUST FILTER: Handles empty strings, null, and undefined gracefully from Keystatic Cloud
const parentCategories = allCategories.filter((cat) => {
  const p = cat.entry.parentCategory;
  return !p || p === '' || p === null || p === undefined;
});

// 🧭 CUSTOM SORTING: Trends slug ko list mein sabsay pehle (Home ke right side par) force karne ke liye
const sortedParentCategories = [...parentCategories].sort((a, b) => {
  if (a.slug === 'trends') return -1;
  if (b.slug === 'trends') return 1;
  return 0;
});

const categoryTree = sortedParentCategories.map((parent) => ({
  ...parent,
  children: allCategories.filter((cat) => cat.entry.parentCategory === parent.slug),
}));
---

<header class="bg-white border-b border-neutral-200/80 sticky top-0 z-50 antialiased font-sans">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {/* 🧭 TOP BRAND IDENTITY LAYER */}
    <div class="grid grid-cols-3 items-center py-6 border-b border-neutral-100 relative">
      
      {/* 🔍 LEFT SIDE: POLISHED EMBEDDED SEARCH SWITCH */}
      <div class="flex items-center justify-start h-8 relative">
        <input type="checkbox" id="header-search-toggle" class="peer hidden" />
        
        <label for="header-search-toggle" class="cursor-pointer text-neutral-600 hover:text-black transition-all duration-300 peer-checked:opacity-0 peer-checked:pointer-events-none p-1.5 z-10 block">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </label>

        <form action="/search" method="GET" class="absolute left-0 top-1/2 -translate-y-1/2 h-full flex items-center border-b border-neutral-950 bg-white transform -translate-x-4 opacity-0 pointer-events-none peer-checked:translate-x-0 peer-checked:opacity-100 peer-checked:pointer-events-auto transition-all duration-300 ease-out w-48 sm:w-56 py-0.5 z-20">
          <button type="submit" class="text-neutral-500 hover:text-black transition p-1 mr-1" aria-label="Submit Search">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </button>
          <input 
            type="text" 
            name="q" 
            placeholder="Search trends..." 
            class="w-full bg-transparent text-[11px] font-light tracking-wide focus:outline-none placeholder-neutral-400 text-neutral-800 pr-1"
            required
          />
          <label for="header-search-toggle" class="cursor-pointer text-neutral-400 hover:text-black text-[10px] font-light pl-2 pr-1 border-l border-neutral-200">
            ✕
          </label>
        </form>
      </div>

      {/* 👑 CENTER SIDE: LUXURY HIGH-TRACKING BRAND IDENTITY LOGO */}
      <div class="text-center">
        <a href="/" class="inline-block no-underline">
          {settings.logoImage ? (
            <img src={settings.logoImage} alt={settings.siteName} class="h-8 max-h-9 mx-auto object-contain" />
          ) : (
            <span class="text-xl sm:text-2xl md:text-3xl font-serif tracking-[0.35em] uppercase text-neutral-950 hover:text-neutral-700 transition duration-300 block font-light whitespace-nowrap pl-[0.35em]">
              {settings.siteName || "FASHION EDITORIAL"}
            </span>
          )}
        </a>
      </div>

      {/* 📱 RIGHT SIDE: RESPONSIVE ACTIONS BAR */}
      <div class="flex items-center justify-end">
        <button id="mobile-menu-button" class="md:hidden p-2 text-neutral-700 hover:text-neutral-950 transition" aria-label="Toggle Navigation Menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        {/* Empty decorative space on desktop to lock exact logo grid centering metrics */}
        <div class="hidden md:block w-8 h-8"></div>
      </div>

    </div>

    {/* 🧷 DESKTOP NAVIGATION ROW */}
    <div class="hidden md:flex items-center justify-center flex-wrap gap-x-9 gap-y-2 py-4">
      <a href="/" class={`text-[10.5px] tracking-[0.25em] uppercase font-bold transition duration-200 pb-1 shrink-0 ${currentPath === '/' ? 'text-neutral-950 border-b border-neutral-950' : 'text-neutral-400 hover:text-neutral-950'}`}>
        Home
      </a>

      {categoryTree.map((parent) => (
        <div class="relative group shrink-0">
          <a
            href={`/category/${parent.slug}/`}
            class={`flex items-center gap-1 text-[10.5px] tracking-[0.25em] uppercase font-bold transition duration-200 pb-1 ${currentPath === `/category/${parent.slug}` ? 'text-neutral-950 border-b border-neutral-950' : 'text-neutral-400 hover:text-neutral-950'}`}>
            {parent.entry.name}
            {parent.children.length > 0 && (
              <svg class="w-2.5 h-2.5 text-neutral-400 group-hover:text-neutral-950 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>

          {/* Dynamic Cascading Dropdown List Container */}
          {parent.children.length > 0 && (
            <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 absolute left-1/2 -translate-x-1/2 top-full pt-3 transition-all duration-300 z-[100]">
              <div class="bg-white border border-neutral-200/60 shadow-xl py-2 min-w-[210px] rounded-sm">
                {parent.children.map((child) => (
                  <a
                    href={`/category/${child.slug}/`}
                    class="block px-5 py-2.5 text-[11px] tracking-widest uppercase text-neutral-500 hover:bg-neutral-50 hover:text-neutral-950 font-medium transition duration-150">
                    {child.entry.name}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}
    </div>

  </div>

  {/* 📱 MOBILE SIDE DRAWER NAVIGATION INTERACTION STACK */}
  <div id="mobile-menu" class="hidden md:hidden border-t border-neutral-200 bg-white">
    <div class="max-w-7xl mx-auto px-6 py-4 space-y-3">
      
      <form action="/search" method="GET" class="relative flex items-center border border-neutral-200 rounded-sm bg-neutral-50 px-3 py-2 my-2">
        <input 
          type="text" 
          name="q" 
          placeholder="Search fashion trends..." 
          class="w-full bg-transparent text-xs font-light focus:outline-none placeholder-neutral-400"
          required
        />
        <button type="submit" class="text-neutral-500" aria-label="Execute Search">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
      </form>

      <a href="/" class="block py-2 text-xs font-bold uppercase tracking-wider text-neutral-700 hover:text-neutral-950 transition border-b border-neutral-50 pb-1">Home</a>

      {categoryTree.map((parent) => (
        <div class="mobile-category-group border-b border-neutral-50 pb-1">
          <div class="flex items-center justify-between">
            <a href={`/category/${parent.slug}/`} class="block py-2 text-xs font-bold uppercase tracking-wider text-neutral-700 hover:text-neutral-950 transition flex-1">
              {parent.entry.name}
            </a>
            {parent.children.length > 0 && (
              <button class="mobile-category-toggle p-2 text-neutral-400" aria-label="Expand Subcategories Tree">
                <svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            )}
          </div>
          {parent.children.length > 0 && (
            <div class="mobile-category-children hidden pl-4 border-l border-neutral-100 ml-1 space-y-1">
              {parent.children.map((child) => (
                <a href={`/category/${child.slug}/`} class="block py-1.5 text-xs text-neutral-500 hover:text-neutral-950 transition">
                  {child.entry.name}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</header>

<script>
  document.getElementById('mobile-menu-button')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-category-toggle').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const group = btn.closest('.mobile-category-group');
      group?.querySelector('.mobile-category-children')?.classList.toggle('hidden');
      btn.querySelector('svg')?.classList.toggle('rotate-180');
    });
  });
</script>
