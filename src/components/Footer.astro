---
const currentYear = new Date().getFullYear();
---

<footer class="bg-black text-white mt-20 md:mt-24 py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <!-- Main Footer Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12 md:mb-16">
      <!-- Brand Column -->
      <div>
        <h3 class="text-lg md:text-xl font-light tracking-widest mb-6">FASHION EDITORIAL</h3>
        <p class="text-xs md:text-sm text-gray-400 font-light leading-relaxed">
          Premium editorial content exploring contemporary fashion, timeless style, and cultural trends. Curated for the discerning reader.
        </p>
      </div>

      <!-- Navigation Links -->
      <div>
        <h4 class="text-xs md:text-sm font-light tracking-widest text-white mb-6 border-b border-gray-800 pb-4">
          EXPLORE
        </h4>
        <ul class="space-y-4 text-xs md:text-sm">
          <li>
            <a href="/" class="text-gray-400 hover:text-white transition-colors duration-300 font-light">
              Home
            </a>
          </li>
          <li>
            <a href="/posts" class="text-gray-400 hover:text-white transition-colors duration-300 font-light">
              All Articles
            </a>
          </li>
          <li>
            <a href="/categories" class="text-gray-400 hover:text-white transition-colors duration-300 font-light">
              Categories
            </a>
          </li>
          <li>
            <a href="/about" class="text-gray-400 hover:text-white transition-colors duration-300 font-light">
              About Us
            </a>
          </li>
        </ul>
      </div>

      <!-- Information -->
      <div>
        <h4 class="text-xs md:text-sm font-light tracking-widest text-white mb-6 border-b border-gray-800 pb-4">
          INFORMATION
        </h4>
        <ul class="space-y-4 text-xs md:text-sm">
          <li>
            <a href="/contact" class="text-gray-400 hover:text-white transition-colors duration-300 font-light">
              Contact Us
            </a>
          </li>
          <li>
            <a href="/privacy-policy" class="text-gray-400 hover:text-white transition-colors duration-300 font-light">
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="/disclaimer" class="text-gray-400 hover:text-white transition-colors duration-300 font-light">
              Disclaimer
            </a>
          </li>
          <li>
            <a href="/rss.xml" class="text-gray-400 hover:text-white transition-colors duration-300 font-light">
              RSS Feed
            </a>
          </li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="text-xs md:text-sm font-light tracking-widest text-white mb-6 border-b border-gray-800 pb-4">
          CONNECT
        </h4>
        <div class="flex gap-6 mb-6">
          <a
            href="https://instagram.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-white transition-colors duration-300"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073z"/>
            </svg>
          </a>
          <a
            href="https://twitter.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-white transition-colors duration-300"
            aria-label="Twitter"
          >
            <svg class="w-5 h-5 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417a9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
          <a
            href="https://pinterest.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-white transition-colors duration-300"
            aria-label="Pinterest"
          >
            <svg class="w-5 h-5 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-gray-800 my-12"></div>

    <!-- Bottom Copyright Section -->
    <div class="text-center">
      <p class="text-xs md:text-sm text-gray-400 font-light tracking-wide">
        &copy; {currentYear} Fashion Editorial. All rights reserved.
      </p>
      <p class="text-xs text-gray-500 font-light mt-3">
        Designed with precision for the modern editorial reader.
      </p>
    </div>
  </div>
</footer>
