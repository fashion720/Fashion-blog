---
interface Props {
  title: string;
  slug: string;
  description: string;
  featuredImage?: string;
  author?: string;
  publishedDate: string;
  categories?: string[];
  tags?: string[];
}

const {
  title,
  slug,
  description,
  featuredImage,
  author,
  publishedDate,
  categories = [],
  tags = [],
} = Astro.props;

function resolveImage(img?: string) {
  if (!img) return '/images/placeholder.jpg';
  if (img.startsWith('/')) return img;
  return `/images/posts/${img}`;
}

const imgSrc = resolveImage(featuredImage);

const formattedDate = new Date(publishedDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// ⚡ CLEAN INTENT LINKS
const siteUrl = 'https://fashionblog.com'; // Change to your live domain
const postUrl = encodeURIComponent(`${siteUrl}/posts/${slug}`);
const pinImage = encodeURIComponent(`${siteUrl}${imgSrc}`);
const pinTitle = encodeURIComponent(title);
---

<article class="post-card group w-full bg-transparent">
  <div class="overflow-hidden w-full relative block bg-neutral-100">
    
    <a href={`/posts/${slug}`} class="block no-underline">
      <img
        src={imgSrc}
        alt={title}
        width="600"
        height="800"
        loading="lazy"
        decoding="async"
        /* data-pin-nopin Pinterest ki auto script ko doosra duplicate button lagane se rokega */
        data-pin-nopin="true"
        class="w-full h-auto object-contain transition-transform duration-500 group-hover:scale-102 block relative z-10"
      />
    </a>

    <a 
      href={`https://pinterest.com/pin/create/button/?url=${postUrl}&media=${pinImage}&description=${pinTitle}`}
      target="_blank"
      rel="noopener noreferrer"
      class="absolute top-3 left-3 bg-red-600 text-white flex items-center justify-center gap-1.5 px-3 py-1.5 rounded-full shadow-lg opacity-0 group-hover:opacity-100 transition-all duration-200 text-[11px] font-bold tracking-wide uppercase hover:bg-red-700 z-30 pointer-events-auto no-underline"
      title="Save to Pinterest"
    >
      <svg class="w-3.5 h-3.5 fill-white" viewBox="0 0 24 24">
        <path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.992 3.993-.283 1.194.599 2.169 1.775 2.169 2.13 0 3.769-2.247 3.769-5.491 0-2.871-2.063-4.878-5.01-4.878-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.179 23.774 10.551 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/>
      </svg>
      Save
    </a>
  </div>

  <div class="text-left pt-3 px-0">
    <a href={`/posts/${slug}`} class="block no-underline">
      {categories.length > 0 && (
        <span class="block text-[11px] font-bold uppercase tracking-widest text-[#bba15c] mb-1">
          {categories[0].replace(/-/g, ' ')}
        </span>
      )}
      <h3 class="text-lg font-medium tracking-tight text-neutral-900 mb-1.5 group-hover:text-neutral-600 transition-colors duration-200 leading-tight">
        {title}
      </h3>
      <p class="text-[13px] font-normal text-neutral-500 leading-relaxed line-clamp-2 mb-2">
        {description}
      </p>
    </a>
    <div class="text-[10px] uppercase tracking-widest text-neutral-400">
      <time datetime={publishedDate}>{formattedDate}</time>
    </div>
  </div>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
