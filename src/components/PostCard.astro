---
interface Props {
  title: string;
  slug: string;
  description: string;
  featuredImage?: string;
  author?: string;
  publishedDate: string;
  categories?: string[];
  tags?: string[];
}

const {
  title,
  slug,
  description,
  featuredImage,
  author,
  publishedDate,
  categories = [],
  tags = [],
} = Astro.props;

function resolveImage(img?: string) {
  if (!img) return '/images/placeholder.jpg';
  if (img.startsWith('/')) return img;
  return `/images/posts/${img}`;
}

const imgSrc = resolveImage(featuredImage);

const formattedDate = new Date(publishedDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card group w-full bg-transparent flex flex-col">
  <div class="overflow-hidden w-full aspect-[3/4] relative block bg-neutral-100 rounded-sm containment-layout">
    <a href={`/posts/${slug}`} class="block w-full h-full no-underline pointer-events-auto">
      <img
        src={imgSrc}
        alt={title}
        width="600"
        height="800"
        loading="lazy"
        decoding="async"
        /* Double programmatic block mapping to fully blind peripheral engine hooks */
        data-pin-nopin="true"
        data-pin-nohover="true"
        class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-102 block pointer-events-none select-none z-10"
      />
    </a>
  </div>

  <div class="text-left pt-4 flex flex-col flex-1 min-w-0">
    <a href={`/posts/${slug}`} class="block no-underline flex-1">
      {categories.length > 0 && (
        <span class="block text-[10px] font-bold uppercase tracking-widest text-[#bba15c] mb-1">
          {categories[0].replace(/-/g, ' ')}
        </span>
      )}
      
      {/* ⚡ HEIGHT SECURITY LAYER: Prevents alignment breakage from titles scaling into multiple strings */}
      <h3 class="text-base font-serif font-light tracking-tight text-neutral-950 mb-1.5 group-hover:text-neutral-600 transition-colors duration-200 leading-snug line-clamp-2 min-h-[44px] md:min-h-[48px]">
        {title}
      </h3>
      
      <p class="text-[13px] font-light text-neutral-500 leading-relaxed line-clamp-2 mb-3">
        {description}
      </p>
    </a>
    
    <div class="text-[9px] uppercase tracking-[0.15em] text-neutral-400 mt-auto pt-1 border-t border-neutral-100/40">
      <time datetime={publishedDate}>{formattedDate}</time>
    </div>
  </div>
</article>

<style is:global>
  /* 🔒 SECURE ANTI-INTERCEPTOR STYLES */
  .containment-layout {
    contain: paint !important;
  }
  .containment-layout span,
  .containment-layout [class*="PIN_"],
  .containment-layout [id*="PIN_"],
  [data-pin-log="button_hover"] {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    pointer-events: none !important;
    width: 0 !important;
    height: 0 !important;
  }
</style>
