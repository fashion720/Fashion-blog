---
/**
 * Ad Slot Component
 * Renders a fixed-size <ins> tag dynamically via Keystatic config toggle.
 */
import { getSiteSettings } from '../lib/keystatic-reader';

interface Props {
  slot: 'header' | 'sidebar' | 'in-content' | 'footer' | 'sticky';
  className?: string;
  format?: 'auto' | 'rectangle' | 'horizontal' | 'vertical';
}

const {
  slot,
  className = '',
  format = 'auto',
} = Astro.props;

// 🛠️ FETCH KEYSTATIC DYNAMIC SETTINGS
const settings = await getSiteSettings();
const IS_ADS_ENABLED = settings?.adsenseEnabled === true;

// AdSense Client Publisher ID from Keystatic or fallback env
const ADSENSE_CLIENT = settings?.adsenseClientId || import.meta.env.PUBLIC_ADSENSE_CLIENT;

// Read Slots dynamically from Keystatic settings fields
const adSlotIds: Record<string, string | undefined> = {
  header: settings?.adSlotHeader,
  sidebar: settings?.adSlotSidebar,
  'in-content': settings?.adSlotContent,
  footer: settings?.adSlotFooter,
  sticky: settings?.adSlotSidebar, // Default mapping fallback
};

const slotId = adSlotIds[slot];

// Fixed dimensions = no layout shift (CLS) when the ad loads in
const sizeClasses: Record<string, string> = {
  auto: 'min-h-[250px] max-h-[300px]',
  rectangle: 'w-full max-w-[300px] h-[250px] mx-auto',
  horizontal: 'w-full h-[90px]',
  vertical: 'w-full max-w-[300px] h-[600px] mx-auto',
};
---

{/* ⚡ CRUCIAL: If ads are turned off globally in Keystatic, render absolutely NOTHING */}
{IS_ADS_ENABLED && slotId && ADSENSE_CLIENT ? (
  <div
    class={`ad-container ad-slot-${slot} ${sizeClasses[format]} ${className}`}
    data-ad-slot={slot}
  >
    <ins
      class="adsbygoogle"
      style="display:block;width:100%;height:100%;"
      data-ad-client={ADSENSE_CLIENT}
      data-ad-slot={slotId}
      data-ad-format={format}
      data-full-width-responsive="true"
    ></ins>
  </div>
) : null}

{/* Push THIS slot initialization string execution only if enabled */}
{IS_ADS_ENABLED && slotId && ADSENSE_CLIENT && (
  <script is:inline>
    (window.adsbygoogle = window.adsbygoogle || []).push({});
  </script>
)}

<style>
  .ad-container {
    margin: 1.5rem auto;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .ad-slot-sidebar,
  .ad-slot-sticky {
    position: sticky;
    top: 5rem;
  }

  @media (max-width: 768px) {
    .ad-slot-sidebar,
    .ad-slot-sticky {
      position: static;
    }
  }
</style>
