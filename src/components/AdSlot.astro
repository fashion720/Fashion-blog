---
/**
 * Ad Slot Component
 * Renders a fixed-size <ins> tag. The AdSense loader <script> is loaded ONCE
 * globally in Layout.astro — this component only pushes its own slot,
 * avoiding duplicate-script / Auto Ads conflicts.
 */

interface Props {
  slot: 'header' | 'sidebar' | 'in-content' | 'footer' | 'sticky';
  className?: string;
  format?: 'auto' | 'rectangle' | 'horizontal' | 'vertical';
}

const {
  slot,
  className = '',
  format = 'auto',
} = Astro.props;

const ADSENSE_CLIENT = import.meta.env.PUBLIC_ADSENSE_CLIENT;
const ADSENSE_ENABLED = import.meta.env.PUBLIC_ADSENSE_ENABLED === 'true';

const adSlotIds: Record<string, string | undefined> = {
  header: import.meta.env.PUBLIC_ADSENSE_SLOT_HEADER,
  sidebar: import.meta.env.PUBLIC_ADSENSE_SLOT_SIDEBAR,
  'in-content': import.meta.env.PUBLIC_ADSENSE_SLOT_CONTENT,
  footer: import.meta.env.PUBLIC_ADSENSE_SLOT_FOOTER,
  sticky: import.meta.env.PUBLIC_ADSENSE_SLOT_STICKY,
};

const slotId = adSlotIds[slot];

// Fixed dimensions = no layout shift (CLS) when the ad loads in
const sizeClasses: Record<string, string> = {
  auto: 'min-h-[250px] max-h-[300px]',
  rectangle: 'w-full max-w-[300px] h-[250px] mx-auto',
  horizontal: 'w-full h-[90px]',
  vertical: 'w-full max-w-[300px] h-[600px] mx-auto',
};
---

<div
  class={`ad-container ad-slot-${slot} ${sizeClasses[format]} ${className}`}
  data-ad-slot={slot}
>
  {ADSENSE_ENABLED && ADSENSE_CLIENT && slotId ? (
    <ins
      class="adsbygoogle"
      style="display:block;width:100%;height:100%;"
      data-ad-client={ADSENSE_CLIENT}
      data-ad-slot={slotId}
      data-ad-format={format}
      data-full-width-responsive="true"
    ></ins>
  ) : (
    <div class="ad-placeholder">
      <span class="ad-label">Advertisement</span>
    </div>
  )}
</div>

{/* Push THIS slot only. The adsbygoogle loader <script src=...> is in Layout.astro */}
{ADSENSE_ENABLED && ADSENSE_CLIENT && slotId && (
  <script is:inline>
    (window.adsbygoogle = window.adsbygoogle || []).push({});
  </script>
)}

<style>
  .ad-container {
    margin: 1.5rem auto;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .ad-slot-sidebar,
  .ad-slot-sticky {
    position: sticky;
    top: 5rem;
  }

  .ad-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  }

  .ad-label {
    text-transform: uppercase;
    font-size: 0.75rem;
    color: #9ca3af;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .ad-slot-sidebar,
    .ad-slot-sticky {
      position: static;
    }
  }
</style>
