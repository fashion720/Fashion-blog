---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Disclaimer | Outfit Edits";
const pageDescription = "Disclaimer for Outfit Edits (outfitedits.com), including affiliate, advertising, and general content disclosures.";
const lastUpdated = "July 1, 2026";
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl md:text-4xl font-bold mb-2">Disclaimer</h1>
    <p class="text-sm text-gray-600 mb-6">Last updated: {lastUpdated}</p>

    <div class="prose prose-lg max-w-none">
      <p>
        The information provided on Outfit Edits (outfitedits.com) is for
        general informational and entertainment purposes only. All
        content on this Site, including outfit ideas, styling tips, and
        DIY fashion guides, is published in good faith. However, we make
        no representation or warranty of any kind, express or implied,
        regarding the accuracy, adequacy, validity, reliability,
        availability, or completeness of any information on the Site.
      </p>

      <h2 class="text-2xl font-semibold mt-8 mb-3">No Professional Advice</h2>
      <p>
        Content on this Site is not intended as professional styling,
        fashion, or purchasing advice tailored to any individual. Outfit
        suggestions, product recommendations, and DIY instructions are
        offered as inspiration. Results may vary depending on materials,
        body type, personal preference, and execution. You are
        responsible for using your own judgment before attempting any DIY
        project featured on the Site.
      </p>

      <h2 class="text-2xl font-semibold mt-8 mb-3">DIY and Safety Disclaimer</h2>
      <p>
        Some posts on this Site include do it yourself fashion projects
        that may involve cutting, bleaching, sewing, or altering clothing
        and accessories. These projects are shared for inspiration only.
        Outfit Edits is not responsible for any damage to clothing,
        property, or personal injury resulting from attempting any DIY
        project described on the Site. Always exercise caution and follow
        proper safety practices when working with sharp tools or
        chemicals such as bleach.
      </p>

      <h2 class="text-2xl font-semibold mt-8 mb-3">
        Affiliate and Advertising Disclosure
      </h2>
      <p>
        Outfit Edits may contain affiliate links, meaning we may earn a
        small commission if you click through and make a purchase, at no
        additional cost to you. We may also display advertisements served
        by third party advertising networks, including Google AdSense and
        Mediavine. These ads may use cookies and similar technologies to
        show relevant content. We only recommend products or brands we
        believe may be of interest to our readers, but we encourage you
        to do your own research before making a purchase.
      </p>

      <h2 class="text-2xl font-semibold mt-8 mb-3">External Links Disclaimer</h2>
      <p>
        The Site may contain links to external websites that are not
        provided or maintained by us. We do not guarantee the accuracy,
        relevance, timeliness, or completeness of any information on
        these external websites and are not responsible for their content
        or privacy practices.
      </p>

      <h2 class="text-2xl font-semibold mt-8 mb-3">Images and Content Use</h2>
      <p>
        Images and content published on this Site are either originally
        created for Outfit Edits or used with appropriate rights or
        permissions. If you believe any content on this Site infringes
        your rights, please contact us so we can address it promptly.
      </p>

      <h2 class="text-2xl font-semibold mt-8 mb-3">Changes to This Disclaimer</h2>
      <p>
        We may update this Disclaimer from time to time. Any changes will
        be posted on this page with an updated revision date.
      </p>

      <h2 class="text-2xl font-semibold mt-8 mb-3">Contact Us</h2>
      <p>
        If you have any questions about this Disclaimer, please contact
        us at
        <a href="mailto:dreamharbor18@gmail.com" class="underline">
          dreamharbor18@gmail.com
        </a>
        or
        <a href="mailto:hamzahameed9810@gmail.com" class="underline">
          hamzahameed9810@gmail.com
        </a>
        or visit our <a href="/contact" class="underline">Contact page</a>.
      </p>
    </div>
  </main>
</Layout>
