---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getAllCategories } from '../../lib/keystatic-reader';

const categories = await getAllCategories();
---

<Layout title="Categories - Fashion Blog" description="Browse fashion content by category.">
  <Header currentPath="/categories" />

  <main class="min-h-screen container mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold mb-10">Categories</h1>

    {categories.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {categories.map((cat) => (
          <a
            href={`/category/${cat.slug}/`}
            class="block p-6 rounded-xl border border-gray-200 hover:shadow-md transition"
            style={{ borderTopColor: cat.entry.color, borderTopWidth: '4px' }}
          >
            <h2 class="text-xl font-bold mb-2">{cat.entry.name}</h2>
            <p class="text-gray-600 text-sm">{cat.entry.description}</p>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-gray-600">No categories yet.</p>
    )}
  </main>

  <Footer />
</Layout>
