---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found - Fashion Blog">
  <Header />
  <main class="min-h-[60vh] flex items-center justify-center text-center px-4">
    <div>
      <h1 class="text-6xl font-extrabold mb-4">404</h1>
      <p class="text-gray-600 mb-8">Sorry, we couldn't find that page.</p>
      <a href="/" class="bg-black text-white px-6 py-3 rounded-lg hover:bg-gray-800 transition font-semibold">
        Back to Home
      </a>
    </div>
  </main>
  <Footer />
</Layout>
