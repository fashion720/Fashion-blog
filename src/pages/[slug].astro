---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getAllPages } from '../lib/keystatic-reader';

export async function getStaticPaths() {
  const pages = await getAllPages();
  
  if (!pages || pages.length === 0) {
    return [];
  }
  
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;

if (!page) {
  return Astro.redirect('/404');
}

const { entry } = page;

// ⚡ Dynamic content resolution without external renderer dependencies
const contentData = await entry.content();
---

<Layout 
  title={`${entry?.title || 'Page'} - Fashion Editorial`} 
  description={entry?.description || ''}
>
  <Header currentPath={`/${page.slug}`} />

  <main class="max-w-4xl mx-auto px-6 py-16 md:py-24 bg-[#faf9f6] min-h-[60vh] antialiased">
    <header class="mb-12 text-center space-y-4">
      <h1 class="text-3xl md:text-5xl font-serif font-light tracking-tight text-neutral-950 capitalize">
        {entry?.title.replace(/-/g, ' ')}
      </h1>
      <div class="w-12 h-[1px] bg-[#bba15c] mx-auto pt-1"></div>
    </header>

    <div class="prose prose-neutral max-w-none legal-page-content text-[15px] md:text-[16px] text-neutral-800 leading-relaxed font-light tracking-wide">
      {/* Fallback secure content node rendering mapping */}
      {contentData && typeof contentData === 'string' ? (
        <div set:html={contentData} />
      ) : contentData && typeof contentData === 'object' && 'children' in contentData ? (
        <p>{JSON.stringify(contentData)}</p>
      ) : (
        <p class="text-neutral-400 italic">Content editing via Admin Panel.</p>
      )}
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  .legal-page-content p {
    margin-bottom: 1.5rem !important;
    line-height: 1.85 !important;
    color: #262626 !important;
  }
  .legal-page-content h2, .legal-page-content h3 {
    font-family: ui-serif, Georgia, Cambria, serif !important;
    font-weight: 400 !important;
    color: #0a0a0a !important;
    margin-top: 2rem !important;
    margin-bottom: 0.75rem !important;
  }
  .legal-page-content h2 {
    font-size: 1.5rem !important;
    border-b: 1px solid #e5e5e5;
    padding-bottom: 0.3rem;
  }
  .legal-page-content a {
    color: #bba15c !important;
    text-decoration-line: underline !important;
    text-underline-offset: 4px;
  }
</style>
