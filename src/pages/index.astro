---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import {
  getAllPosts,
  getAllCategories,
  getPostsByCategory,
  getSiteSettings,
} from '../lib/keystatic-reader';

const settings = await getSiteSettings();
const allCategories = await getAllCategories();
const parentCategories = allCategories.filter((cat) => !cat.entry.parentCategory);

const allPosts = await getAllPosts();

// Hero = latest isFeatured post
const featuredPosts = allPosts.filter((p) => p.entry.isFeatured);
const heroPost = featuredPosts[0] ?? allPosts[0];

// Secondary posts (exclude hero, prefer posts with images, show next 3)
const secondaryPosts = allPosts
  .filter((p) => p.slug !== heroPost?.slug && p.entry.featuredImage)
  .slice(0, 3);

// Category sections
const categoryWithPosts = await Promise.all(
  parentCategories.map(async (cat) => {
    const posts = await getPostsByCategory(cat.slug);
    return { category: cat, posts: posts.slice(0, 3) };
  })
);
const activeCategoryWithPosts = categoryWithPosts.filter((c) => c.posts.length > 0);

function img(src?: string) {
  if (!src) return '/images/placeholder.jpg';
  return src.startsWith('/') ? src : `/images/posts/${src}`;
}

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', {
    month: 'long', day: 'numeric', year: 'numeric',
  });
}
---

<Layout title={`${settings.siteName} — ${settings.tagline}`}>
  <Header currentPath="/" />

  <main style="background:var(--ivory); min-height:100vh;">

    <!-- ══════════════════════════════════════════════
         HERO
    ══════════════════════════════════════════════ -->
    {heroPost && (
      <section class="hero-section">
        <div style="max-width:1280px; margin:0 auto; padding:3rem 1.5rem 3.5rem;">
          <a href={`/posts/${heroPost.slug}`}
             style="display:flex; flex-wrap:wrap; gap:3.5rem; align-items:center; text-decoration:none;">

            <!-- Image -->
            <div class="hero-image-wrap" style="flex:1; min-width:280px; max-width:580px; border-radius:2px;">
              <img
                src={img(heroPost.entry.featuredImage)}
                alt={heroPost.entry.title}
              />
            </div>

            <!-- Text -->
            <div style="flex:1; min-width:260px;">
              {heroPost.entry.categories?.[0] && (
                <p class="hero-eyebrow" style="margin-bottom:1.25rem;">
                  {heroPost.entry.categories[0]}
                </p>
              )}
              <h1 class="hero-title" style="margin-bottom:1.25rem;">
                {heroPost.entry.title}
              </h1>
              <p class="hero-desc" style="margin-bottom:2rem; max-width:42ch;">
                {heroPost.entry.description}
              </p>
              <div style="display:flex; align-items:center; gap:1.5rem;">
                <span class="hero-cta">Read More →</span>
                <span class="card-date">{fmtDate(heroPost.entry.publishedDate)}</span>
              </div>
            </div>

          </a>
        </div>
      </section>
    )}

    <!-- Ad -->
    <div style="max-width:1280px; margin:0 auto; padding:1.5rem;">
      <AdSlot slot="header" format="horizontal" />
    </div>

    <!-- ══════════════════════════════════════════════
         THE LATEST — Pinterest masonry strip
    ══════════════════════════════════════════════ -->
    {secondaryPosts.length > 0 && (
      <section style="border-bottom:1px solid rgba(138,133,130,0.15); padding:3rem 0;">
        <div style="max-width:1280px; margin:0 auto; padding:0 1.5rem;">

          <!-- Header -->
          <div style="display:flex; align-items:center; gap:1rem; margin-bottom:2.25rem;">
            <span class="section-title">The Latest</span>
            <div class="section-rule"></div>
            <a href="/posts" class="section-link">All Stories →</a>
          </div>

          <!-- Pinterest-style masonry grid -->
          <div class="pinterest-grid">
            {secondaryPosts.map((post, i) => (
              <a href={`/posts/${post.slug}`}
                 class={`card-3d post-card reveal reveal-delay-${i + 1} ${i === 0 ? 'card-featured' : 'card-small'}`}
                 style="display:block; text-decoration:none;">
                <div class="card-inner">
                  <div class="card-img">
                    <img src={img(post.entry.featuredImage)} alt={post.entry.title} />
                  </div>
                  <div style="padding:1.1rem 1.2rem 1.25rem;">
                    {post.entry.categories?.[0] && (
                      <p class="card-category" style="margin-bottom:0.5rem;">
                        {post.entry.categories[0]}
                      </p>
                    )}
                    <h3 class="card-title" style="margin-bottom:0.5rem;">{post.entry.title}</h3>
                    <p class="card-desc" style="margin-bottom:0.75rem;">{post.entry.description}</p>
                    <p class="card-date">{fmtDate(post.entry.publishedDate)}</p>
                  </div>
                </div>
              </a>
            ))}
          </div>

        </div>
      </section>
    )}

    <!-- ══════════════════════════════════════════════
         CATEGORY SECTIONS
    ══════════════════════════════════════════════ -->
    {activeCategoryWithPosts.map(({ category, posts }, si) => (
      <section style="border-bottom:1px solid rgba(138,133,130,0.15); padding:3.5rem 0;">
        <div style="max-width:1280px; margin:0 auto; padding:0 1.5rem;">

          <!-- Section Header -->
          <div style="display:flex; align-items:center; gap:1rem; margin-bottom:2.25rem;">
            <span class="section-title">{category.entry.name}</span>
            <div class="section-rule"></div>
            <a href={`/category/${category.slug}/`} class="section-link">
              More {category.entry.name} →
            </a>
          </div>

          <!-- 3 posts: first big, next 2 small (Pinterest asymmetry) -->
          {posts.length >= 3 && (
            <div class="pinterest-grid">
              {posts.slice(0, 3).map((post, i) => (
                <a href={`/posts/${post.slug}`}
                   class={`card-3d post-card reveal reveal-delay-${i + 1} ${i === 0 ? 'card-featured' : 'card-small'}`}
                   style="display:block; text-decoration:none;">
                  <div class="card-inner">
                    <div class="card-img">
                      <img src={img(post.entry.featuredImage)} alt={post.entry.title} />
                    </div>
                    <div style="padding:1.1rem 1.2rem 1.25rem;">
                      {post.entry.categories?.[0] && (
                        <p class="card-category" style="margin-bottom:0.5rem;">
                          {post.entry.categories[0]}
                        </p>
                      )}
                      <h3 class="card-title" style="margin-bottom:0.5rem;">{post.entry.title}</h3>
                      <p class="card-desc" style="margin-bottom:0.75rem;">{post.entry.description}</p>
                      <p class="card-date">{fmtDate(post.entry.publishedDate)}</p>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          )}

          {posts.length === 2 && (
            <div class="grid-2col">
              {posts.map((post, i) => (
                <a href={`/posts/${post.slug}`}
                   class={`card-3d post-card reveal reveal-delay-${i + 1}`}
                   style="display:block; text-decoration:none;">
                  <div class="card-inner">
                    <div class="card-img" style="height:240px;">
                      <img src={img(post.entry.featuredImage)} alt={post.entry.title} />
                    </div>
                    <div style="padding:1.1rem 1.2rem 1.25rem;">
                      {post.entry.categories?.[0] && (
                        <p class="card-category" style="margin-bottom:0.5rem;">
                          {post.entry.categories[0]}
                        </p>
                      )}
                      <h3 class="card-title" style="margin-bottom:0.5rem;">{post.entry.title}</h3>
                      <p class="card-desc" style="margin-bottom:0.75rem;">{post.entry.description}</p>
                      <p class="card-date">{fmtDate(post.entry.publishedDate)}</p>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          )}

          {posts.length === 1 && (
            <div style="max-width:420px;">
              <a href={`/posts/${posts[0].slug}`}
                 class="card-3d post-card reveal"
                 style="display:block; text-decoration:none;">
                <div class="card-inner">
                  <div class="card-img" style="height:260px;">
                    <img src={img(posts[0].entry.featuredImage)} alt={posts[0].entry.title} />
                  </div>
                  <div style="padding:1.1rem 1.2rem 1.25rem;">
                    <h3 class="card-title" style="margin-bottom:0.5rem;">{posts[0].entry.title}</h3>
                    <p class="card-desc">{posts[0].entry.description}</p>
                  </div>
                </div>
              </a>
            </div>
          )}

        </div>
      </section>
    ))}

    <!-- ══════════════════════════════════════════════
         NEWSLETTER — Dark luxury panel
    ══════════════════════════════════════════════ -->
    <section class="newsletter-section" style="padding:5rem 1.5rem;">
      <div style="max-width:540px; margin:0 auto; text-align:center; position:relative; z-index:1;">
        <p class="section-eyebrow" style="margin-bottom:1rem;">Newsletter</p>
        <h2 class="newsletter-title" style="margin-bottom:1rem;">Stay in the Loop</h2>
        <div class="gold-divider" style="margin:0 auto 1.5rem;"></div>
        <p style="font-size:0.875rem; color:rgba(255,255,255,0.5); margin-bottom:2rem; line-height:1.75;">
          Get the latest fashion trends and styling tips delivered to your inbox.
        </p>
        <form style="display:flex; gap:0; max-width:420px; margin:0 auto;">
          <input
            type="email"
            placeholder="Your email address"
            class="newsletter-input"
            required
          />
          <button type="submit" class="newsletter-btn">Subscribe</button>
        </form>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<!-- ══════════════════════════════════════════════
     JAVASCRIPT: Scroll Reveal + 3D Tilt
══════════════════════════════════════════════ -->
<script>
  // ── Scroll Reveal ──
  const revealEls = document.querySelectorAll<HTMLElement>('.reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  revealEls.forEach((el) => observer.observe(el));

  // ── 3D Tilt on mouse move ──
  const cards = document.querySelectorAll<HTMLElement>('.card-3d');

  cards.forEach((card) => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const dx = (e.clientX - cx) / (rect.width / 2);
      const dy = (e.clientY - cy) / (rect.height / 2);
      const tiltX = -(dy * 6);
      const tiltY = dx * 6;
      card.style.transform = `perspective(900px) rotateX(${tiltX}deg) rotateY(${tiltY}deg) translateY(-8px)`;
    });

    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
    });
  });
</script>
