---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import { getAllPosts, getAllCategories, getPostsByCategory, getSiteSettings } from '../lib/keystatic-reader';

const settings = await getSiteSettings();
const allCategories = await getAllCategories();
const parentCategories = allCategories.filter((cat) => !cat.entry.parentCategory);

// Category ke liye articles fetch karo (max 3, date ke hisaab se latest pehle)
const categoryWithPosts = await Promise.all(
  parentCategories.map(async (cat) => {
    const posts = await getPostsByCategory(cat.slug);
    const sorted = posts
      .filter((p) => !p.entry.isDraft)
      .sort((a, b) => new Date(b.entry.publishedDate).getTime() - new Date(a.entry.publishedDate).getTime());
    return { category: cat, posts: sorted.slice(0, 3) };
  })
);

const activeCategoryWithPosts = categoryWithPosts.filter((c) => c.posts.length > 0);

// Hero: sabse latest featured post
const allPosts = await getAllPosts();
const sortedPosts = allPosts
  .filter((p) => !p.entry.isDraft)
  .sort((a, b) => new Date(b.entry.publishedDate).getTime() - new Date(a.entry.publishedDate).getTime());

const featuredPosts = sortedPosts.filter((p) => p.entry.isFeatured);
const heroPost = featuredPosts[0] || sortedPosts[0];

function getImageSrc(img?: string) {
  if (!img) return '/images/placeholder.jpg';
  if (img.startsWith('/')) return img;
  return `/images/posts/${img}`;
}

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<Layout title={`${settings.siteName} — ${settings.tagline}`}>
  <Header currentPath="/" />

  <main class="min-h-screen bg-white">

    <!-- ══ HERO BANNER ══ -->
    {heroPost && (
      <section class="border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 py-10 md:py-16">
          <a href={`/posts/${heroPost.slug}`} class="group block md:flex gap-12 items-center">
            <!-- Hero Image -->
            <div class="md:w-1/2 overflow-hidden rounded-sm mb-6 md:mb-0 bg-gray-100">
              <img
                src={getImageSrc(heroPost.entry.featuredImage)}
                alt={heroPost.entry.title}
                class="w-full h-[420px] object-cover object-top transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <!-- Hero Text -->
            <div class="md:w-1/2">
              {heroPost.entry.categories && heroPost.entry.categories.length > 0 && (
                <p class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-4">
                  {heroPost.entry.categories[0]}
                </p>
              )}
              <h1 class="text-3xl md:text-5xl font-bold text-gray-900 leading-tight mb-4 group-hover:text-gray-700 transition">
                {heroPost.entry.title}
              </h1>
              <p class="text-gray-500 text-lg mb-6 leading-relaxed">
                {heroPost.entry.description}
              </p>
              <p class="text-xs text-gray-400 mb-6">{formatDate(heroPost.entry.publishedDate)}</p>
              <span class="text-sm font-semibold uppercase tracking-wider border-b-2 border-black pb-1">Read More</span>
            </div>
          </a>
        </div>
      </section>
    )}

    <AdSlot slot="header" format="horizontal" className="max-w-7xl mx-auto px-4 mt-6" />

    <!-- ══ CATEGORY SECTIONS (Who What Wear style) ══ -->
    {activeCategoryWithPosts.map(({ category, posts }) => (
      <section class="max-w-7xl mx-auto px-4 py-12 border-b border-gray-100">

        <!-- Category Header -->
        <div class="flex items-center justify-between mb-8">
          <div class="flex items-center gap-4">
            <h2 class="text-xs font-bold tracking-widest uppercase text-gray-900">
              {category.entry.name}
            </h2>
            <div class="hidden md:block h-px bg-gray-200 w-32"></div>
          </div>
          <a
            href={`/category/${category.slug}/`}
            class="text-xs font-semibold tracking-wider uppercase text-gray-400 hover:text-gray-900 transition border-b border-gray-300 hover:border-gray-900 pb-0.5 whitespace-nowrap"
          >
            Read More {category.entry.name} Stories →
          </a>
        </div>

        <!-- 3 Articles Grid -->
        <div class={`grid gap-8 ${
          posts.length === 1
            ? 'grid-cols-1 max-w-sm'
            : posts.length === 2
            ? 'grid-cols-1 md:grid-cols-2'
            : 'grid-cols-1 md:grid-cols-3'
        }`}>
          {posts.map((post) => (
            <a href={`/posts/${post.slug}`} class="group block">
              <!-- Image -->
              <div class="overflow-hidden rounded-sm mb-4 bg-gray-100">
                <img
                  src={getImageSrc(post.entry.featuredImage)}
                  alt={post.entry.title}
                  class="w-full h-56 object-cover object-top transition-transform duration-300 group-hover:scale-105"
                />
              </div>
              <!-- Text -->
              {post.entry.categories && post.entry.categories.length > 0 && (
                <p class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-2">
                  {post.entry.categories[0]}
                </p>
              )}
              <h3 class="text-base md:text-lg font-bold text-gray-900 group-hover:text-gray-600 transition leading-snug mb-2">
                {post.entry.title}
              </h3>
              <p class="text-sm text-gray-500 line-clamp-2 mb-3">{post.entry.description}</p>
              <p class="text-xs text-gray-400">{formatDate(post.entry.publishedDate)}</p>
            </a>
          ))}
        </div>

      </section>
    ))}

    <!-- ══ FALLBACK: agar koi category nahi ══ -->
    {activeCategoryWithPosts.length === 0 && sortedPosts.length > 0 && (
      <section class="max-w-7xl mx-auto px-4 py-12">
        <div class="text-center mb-10">
          <h2 class="text-xs font-bold tracking-widest uppercase text-gray-900 mb-2">The Latest</h2>
          <div class="w-12 h-0.5 bg-black mx-auto"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {sortedPosts.slice(0, 9).map((post) => (
            <a href={`/posts/${post.slug}`} class="group block">
              <div class="overflow-hidden mb-4 rounded-sm bg-gray-100">
                <img
                  src={getImageSrc(post.entry.featuredImage)}
                  alt={post.entry.title}
                  class="w-full h-56 object-cover object-top transition-transform duration-300 group-hover:scale-105"
                />
              </div>
              <h3 class="text-lg font-bold text-gray-900 group-hover:text-gray-600 transition mb-2">{post.entry.title}</h3>
              <p class="text-sm text-gray-500 line-clamp-2">{post.entry.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- ══ EMPTY STATE ══ -->
    {allPosts.length === 0 && (
      <div class="max-w-2xl mx-auto text-center py-32 px-4">
        <p class="text-gray-400 text-lg mb-4">No posts yet — start creating content!</p>
        <p class="text-sm text-gray-400">Open <code class="bg-gray-100 px-2 py-1 rounded">/keystatic</code> to add your first post.</p>
      </div>
    )}

    <!-- ══ NEWSLETTER ══ -->
    <section class="bg-gray-50 border-t border-gray-200 py-16">
      <div class="max-w-xl mx-auto px-4 text-center">
        <h2 class="text-xs font-semibold tracking-widest uppercase text-gray-500 mb-3">Newsletter</h2>
        <p class="text-2xl font-bold text-gray-900 mb-2">Stay in the Loop</p>
        <p class="text-gray-500 mb-8 text-sm">
          Get the latest fashion trends and styling tips delivered to your inbox.
        </p>
        <form class="flex gap-3 max-w-md mx-auto">
          <input
            type="email"
            placeholder="Your email address"
            class="flex-1 px-4 py-3 border border-gray-300 rounded-sm text-sm focus:outline-none focus:border-black"
            required
          />
          <button
            type="submit"
            class="bg-black text-white px-6 py-3 text-xs font-semibold tracking-wider uppercase hover:bg-gray-800 transition rounded-sm"
          >
            Subscribe
          </button>
        </form>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
