---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import PostCard from '../components/PostCard.astro';
import CompactPostRow from '../components/CompactPostRow.astro';
import {
  getAllPosts,
  getAllCategories,
  getPostsByCategory,
  getSiteSettings,
} from '../lib/keystatic-reader';

const settings = await getSiteSettings();
const allCategories = await getAllCategories();
const parentCategories = allCategories.filter((cat) => !cat.entry.parentCategory);

const allPosts = await getAllPosts();

// 💸 MONETIZATION CONFIGURATION
const isMonetized = false; 

// 👑 PURE TEXT IMAGE EXTRACTOR: MDX text se automatic pehli image ka src nikalega (Nayi + Purani sab k liye)
async function getPostImage(post: any) {
  const rawContent = (await post.entry.content()) as string;
  if (!rawContent) return '/images/placeholder.jpg';

  // Fallback 1: Agar sections matrix bana ho
  if (post.entry.sections && post.entry.sections[0]?.image) {
    const img = post.entry.sections[0].image;
    return img.startsWith('/') ? img : `/images/posts/${img}`;
  }

  // Fallback 2: Pure Markdown image syntax check karo -> ![alt](url)
  const match = rawContent.match(/!\[.*?\]\((.*?)\)/);
  if (match && match[1]) {
    return match[1].trim(); // Direct content path return karega bina break kiye
  }

  return '/images/placeholder.jpg';
}

// 👑 AUTOMATIC TEXT EXTRACTOR: Strips markdown syntax and slices the first 140 chars as description overview
async function getPostDescription(post: any, length = 140) {
  const rawContent = (await post.entry.content()) as string;
  if (!rawContent) return "Explore contemporary style and curated fashion insights inside this editorial.";
  
  const cleanText = rawContent
    .replace(/[#*_`~]/g, '') // Remove formatting characters
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // Keep link text, remove URL formatting
    .replace(/^[-\s]*\n/gm, '') // Remove linebreaks
    .trim();

  return cleanText.length > length ? `${cleanText.substring(0, length)}...` : cleanText;
}

// 👑 SECTION 1: MASTER HERO (45% Image / 55% Text Editorial Split Layout)
const flagshipPost = allPosts[0];
const flagshipSlug = flagshipPost ? [flagshipPost.slug] : [];
const flagshipDesc = flagshipPost ? await getPostDescription(flagshipPost, 140) : '';
const flagshipImg = flagshipPost ? await getPostImage(flagshipPost) : '/images/placeholder.jpg';

// 💎 SECTION 2: THE LATEST EDITORIALS (Excluding flagship post)
const latestPosts = allPosts
  .filter((p) => !flagshipSlug.includes(p.slug))
  .slice(0, 3);
const latestSlugs = latestPosts.map(p => p.slug);

// Resolve dynamic asynchronous descriptions AND images array maps for latest editorial stack
const latestPostsResolved = await Promise.all(
  latestPosts.map(async (post) => {
    const desc = await getPostDescription(post, 120);
    const img = await getPostImage(post);
    return { ...post, dynamicDesc: desc, dynamicImg: img };
  })
);

// Combined global dynamic filters to preserve hierarchy limits and block duplicate elements
const globallyExcludedSlugs = [...flagshipSlug, ...latestSlugs];

// 🎨 CATEGORY ALTERNATING RHYTHM DISTRIBUTION MAP
const categoryWithPosts = await Promise.all(
  parentCategories.map(async (cat) => {
    const posts = await getPostsByCategory(cat.slug);
    const filteredPosts = posts.filter((p) => !globallyExcludedSlugs.includes(p.slug));
    
    // Resolve content text items asynchronously inside nested categories maps
    const resolvedCategoryPosts = await Promise.all(
      filteredPosts.map(async (p) => {
        const desc = await getPostDescription(p, 120);
        const img = await getPostImage(p);
        return { ...p, dynamicDesc: desc, dynamicImg: img };
      })
    );

    return { category: cat, posts: resolvedCategoryPosts };
  })
);
const activeCategoryWithPosts = categoryWithPosts.filter((c) => c.posts.length > 0);
---

<Layout title={`${settings.siteName} — ${settings.tagline}`}>
  <Header currentPath="/" />

  <main class="bg-[#F8F6F2] min-h-screen font-sans antialiased text-neutral-900 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 overflow-x-hidden w-full block">

    {/* 👑 SECTION 1: FULLY CENTERED 45/55 EDITORIAL SPLIT HERO */}
    {flagshipPost && (
      <section class="py-8 md:py-20 border-b border-neutral-200/40 w-full max-w-full block overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-[45fr_55fr] gap-x-12 lg:gap-x-20 gap-y-6 items-center w-full">
          
          {/* 🔥 FIXED HERO COVER FRAME: Strict absolute dimension fill eliminates side white grids */}
          <div class="overflow-hidden w-full aspect-[4/5] bg-white p-2 md:p-3 border border-neutral-200/20 shadow-sm rounded-sm relative containment-layout group block select-none shrink-0">
            <a href={`/posts/${flagshipPost.slug}/`} class="absolute inset-0 w-full h-full pointer-events-auto block">
              <img
                src={flagshipImg}
                alt={flagshipPost.entry.title}
                data-pin-nopin="true"
                data-pin-nohover="true"
                loading="eager"
                fetchpriority="high"
                class="w-full h-full object-cover object-center transition-transform duration-700 ease-out group-hover:scale-103 block select-none z-10 absolute inset-0 min-w-full min-h-full"
                onerror="this.onerror=null; this.src='/images/placeholder.jpg';"
              />
            </a>
          </div>

          <div class="space-y-3 md:space-y-5 text-left w-full block overflow-hidden">
            {flagshipPost.entry.categories?.[0] && (
              <span class="block text-[10px] font-bold uppercase tracking-[0.3em] text-[#bba15c]">
                {flagshipPost.entry.categories[0].replace(/-/g, ' ')}
              </span>
            )}
            <a href={`/posts/${flagshipPost.slug}/`} class="block no-underline group max-w-full">
              <h1 class="text-2xl sm:text-4xl md:text-5xl lg:text-5.5xl font-serif font-light tracking-tight text-neutral-950 leading-tight group-hover:text-neutral-700 transition-colors duration-300 line-clamp-2 max-w-full">
                {flagshipPost.entry.title}
              </h1>
            </a>
            <p class="text-neutral-500 text-xs md:text-[15px] leading-relaxed font-light line-clamp-3 w-full">
              {flagshipDesc}
            </p>
            <div class="pt-2">
              <a href={`/posts/${flagshipPost.slug}/`} class="inline-block text-xs uppercase tracking-[0.2em] font-medium border-b border-neutral-950/20 pb-1 text-neutral-950 hover:text-[#bba15c] hover:border-[#bba15c] transition-all duration-300 no-underline group">
                Read Story <span class="inline-block transition-transform duration-300 group-hover:translate-x-1">→</span>
              </a>
            </div>
          </div>

        </div>
      </section>
    )}

    {/* 💎 SECTION 2: LATEST EDITORIALS MATRICES BLOCK */}
    {latestPostsResolved.length > 0 && (
      <section class="py-10 md:py-20 border-b border-neutral-200/40 w-full max-w-full block overflow-hidden">
        <div class="text-center mb-8 md:mb-16 space-y-2">
          <h2 class="text-[11px] font-sans tracking-[0.35em] uppercase text-neutral-950 font-bold">Latest Editorials</h2>
          <div class="w-12 h-[1px] bg-[#bba15c] mx-auto"></div>
        </div>

        <div class="hidden md:grid grid-cols-3 gap-8 w-full">
          {latestPostsResolved.map((post) => (
            <PostCard
              title={post.entry.title}
              slug={post.slug}
              description={post.dynamicDesc}
              featuredImage={post.dynamicImg}
              publishedDate={post.entry.publishedDate}
              categories={post.entry.categories}
            />
          ))}
        </div>

        <div class="block md:hidden space-y-6 w-full max-w-full overflow-hidden">
          {latestPostsResolved.map((post) => (
            <CompactPostRow
              title={post.entry.title}
              slug={post.slug}
              description={post.dynamicDesc}
              featuredImage={post.dynamicImg}
              categories={post.entry.categories}
            />
          ))}
        </div>
      </section>
    )}

    {/* 💸 MONETIZATION PANEL MODULE 1 */}
    {isMonetized && (
      <div class="my-12 p-6 bg-white border border-neutral-200/30 rounded-sm text-center relative max-w-5xl mx-auto shadow-sm/5">
        <span class="absolute -top-2.5 left-4 bg-[#F8F6F2] px-2 text-[9px] font-bold uppercase tracking-widest text-neutral-400">Sponsored</span>
        <AdSlot slot="header" format="horizontal" />
      </div>
    )}

    {/* 🎨 DYNAMIC CATEGORIES LOOP */}
    {activeCategoryWithPosts.map(({ category, posts }, idx) => {
      const isEven = idx % 2 === 0;
      const currentSectionPosts = isEven ? posts.slice(0, 2) : posts.slice(0, 4);
      if (currentSectionPosts.length === 0) return null;

      return (
        <section class="py-10 md:py-20 border-b border-neutral-200/40 last:border-0 w-full max-w-full block overflow-hidden">
          <div class="text-center mb-8 md:mb-16 space-y-2">
            <a href={`/category/${category.slug}/`} class="no-underline group inline-block">
              <h2 class="text-[11px] font-sans tracking-[0.35em] uppercase text-neutral-950 font-bold group-hover:text-neutral-600 transition-colors">
                {category.entry.name}
              </h2>
            </a>
            <div class="w-12 h-[1px] bg-[#bba15c] mx-auto"></div>
          </div>

          {isEven ? (
            /* 🎭 RHYTHM TYPE A: Centered Large 2-Column Row Block Matrix Frame */
            <div class="w-full">
              <div class="hidden md:grid grid-cols-2 gap-10 max-w-5xl 2xl:max-w-6xl mx-auto w-full">
                {currentSectionPosts.map((post) => (
                  <a href={`/posts/${post.slug}/`} class="block no-underline group bg-white p-4 border border-neutral-200/30 shadow-sm transition-all duration-300 hover:shadow rounded-sm space-y-4 w-full box-border overflow-hidden flex flex-col">
                    {/* 🔥 FIXED ROW FRAME: Absolute crop system kills lateral white paddings */}
                    <div class="overflow-hidden w-full aspect-[4/5] bg-neutral-100 rounded-[1px] relative containment-layout shrink-0 select-none">
                      <img
                        src={post.dynamicImg}
                        alt={post.entry.title}
                        data-pin-nopin="true"
                        data-pin-nohover="true"
                        loading="lazy"
                        class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-102 absolute inset-0 min-w-full min-h-full"
                        onerror="this.onerror=null; this.src='/images/placeholder.jpg';"
                      />
                    </div>
                    <div class="space-y-1.5 text-left pt-1 w-full flex-1">
                      <span class="block text-[9px] font-bold uppercase tracking-[0.2em] text-[#bba15c]">
                        {category.entry.name}
                      </span>
                      <h3 class="text-lg md:text-xl font-serif font-light text-neutral-950 leading-tight group-hover:text-neutral-700 transition-colors line-clamp-2">
                        {post.entry.title}
                      </h3>
                      <p class="text-neutral-500 text-xs leading-relaxed line-clamp-2 font-light break-words">
                        {post.dynamicDesc}
                      </p>
                    </div>
                  </a>
                ))}
              </div>

              <div class="block md:hidden space-y-6 w-full max-w-full overflow-hidden">
                {currentSectionPosts.map((post) => (
                  <CompactPostRow
                    title={post.entry.title}
                    slug={post.slug}
                    description={post.dynamicDesc}
                    featuredImage={post.dynamicImg}
                    categories={post.entry.categories}
                  />
                ))}
              </div>
            </div>
          ) : (
            /* 🎭 RHYTHM TYPE B: Grid Matrix Columns Switch Frame */
            <div class="w-full">
              <div class={`hidden md:grid gap-6 w-full ${currentSectionPosts.length === 1 ? 'grid-cols-1 max-w-xl mx-auto' : currentSectionPosts.length === 2 ? 'grid-cols-2 max-w-4xl mx-auto' : currentSectionPosts.length === 3 ? 'grid-cols-3 max-w-6xl mx-auto' : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4'}`}>
                {currentSectionPosts.map((post) => (
                  <PostCard
                    title={post.entry.title}
                    slug={post.slug}
                    description={post.dynamicDesc}
                    featuredImage={post.dynamicImg}
                    publishedDate={post.entry.publishedDate}
                    categories={post.entry.categories}
                  />
                ))}
              </div>

              <div class="block md:hidden space-y-6 w-full max-w-full overflow-hidden">
                {currentSectionPosts.map((post) => (
                  <CompactPostRow
                    title={post.entry.title}
                    slug={post.slug}
                    description={post.dynamicDesc}
                    featuredImage={post.dynamicImg}
                    categories={post.entry.categories}
                  />
                ))}
              </div>
            </div>
          )}
        </section>
      );
    })}

    {/* 💸 MONETIZATION PANEL MODULE 2 */}
    {isMonetized && (
      <div class="my-14 p-6 bg-white border border-neutral-200/30 rounded-sm text-center relative max-w-5xl mx-auto shadow-sm/5">
        <span class="absolute -top-2.5 left-4 bg-[#F8F6F2] px-2 text-[9px] font-bold uppercase tracking-widest text-neutral-400">Sponsored</span>
        <AdSlot slot="footer" format="horizontal" />
      </div>
    )}

    {/* ✉️ LUXURY HIGH-CONTRAST NEWSLETTER MODULE */}
    <section class="bg-neutral-950 text-white py-12 md:py-24 px-4 md:px-6 rounded-sm shadow-xl mt-8 w-full block overflow-hidden">
      <div class="max-w-xl mx-auto text-center space-y-4">
        <span class="text-[10px] tracking-[0.3em] uppercase text-[#bba15c] font-bold">Newsletter</span>
        <h2 class="text-2xl md:text-4xl font-serif font-light tracking-tight">Stay in the Loop</h2>
        <p class="text-xs md:text-sm text-neutral-400 font-light leading-relaxed max-w-xs mx-auto">
          Get the latest fashion edits and timeless style updates directly into your inbox.
        </p>
        <form class="flex flex-col gap-2 max-w-md mx-auto pt-2 w-full">
          <input
            type="email"
            placeholder="Your email address"
            class="w-full bg-neutral-900 border border-neutral-800 text-xs px-4 py-3 text-white focus:outline-none focus:border-[#bba15c] transition-colors"
            required
          />
          <button type="submit" class="w-full bg-white text-neutral-950 font-bold uppercase tracking-widest text-[10px] py-3 hover:bg-[#bba15c] hover:text-white transition duration-300 rounded-none shrink-0">
            Subscribe
          </button>
        </form>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style is:global>
  html, body {
    max-width: 100% !important;
    overflow-x: hidden !important;
  }
  .containment-layout {
    contain: paint !important;
  }
</style>
