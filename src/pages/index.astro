---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import PostCard from '../components/PostCard.astro';
import {
  getAllPosts,
  getAllCategories,
  getPostsByCategory,
  getSiteSettings,
} from '../lib/keystatic-reader';

const settings = await getSiteSettings();
const allCategories = await getAllCategories();
const parentCategories = allCategories.filter((cat) => !cat.entry.parentCategory);

const allPosts = await getAllPosts();

// ✅ STRATEGY CHANGE: Fetch top 2 posts for the split premium hero grid
const heroPosts = allPosts.slice(0, 2);
const heroSlugs = heroPosts.map(p => p.slug);

// ✅ OFFSET LOGIC: Exclude the top 2 hero posts from 'The Latest' list (Shows 3rd, 4th, 5th)
const secondaryPosts = allPosts
  .filter((p) => !heroSlugs.includes(p.slug) && p.entry.featuredImage)
  .slice(0, 3);

// ✅ CATEGORY FILTER LOGIC: Map categories while filtering out top hero posts globally to ensure zero repetition
const categoryWithPosts = await Promise.all(
  parentCategories.map(async (cat) => {
    const posts = await getPostsByCategory(cat.slug);
    const filteredPosts = posts.filter((p) => !heroSlugs.includes(p.slug));
    return { category: cat, posts: filteredPosts.slice(0, 3) };
  })
);
const activeCategoryWithPosts = categoryWithPosts.filter((c) => c.posts.length > 0);
---

<Layout title={`${settings.siteName} — ${settings.tagline}`}>
  <Header currentPath="/" />

  <main class="bg-[#faf9f6] min-height-screen font-sans antialiased text-neutral-900">

    {heroPosts.length > 0 && (
      <section class="border-b border-neutral-200/60 py-12 md:py-14">
        <div class="max-w-7xl mx-auto px-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-12 items-start max-w-4xl mx-auto">
            {heroPosts.map((post) => (
              <a href={`/posts/${post.slug}`} class="block no-underline group space-y-4">
                
                <div class="overflow-hidden w-full h-[280px] md:h-[320px] bg-[#faf9f6] flex items-center justify-center rounded-sm block relative">
                  {post.entry.featuredImage ? (
                    <img
                      src={post.entry.featuredImage?.startsWith('/') ? post.entry.featuredImage : `/images/posts/${post.entry.featuredImage}`}
                      alt={post.entry.title}
                      /* ⚡ NO-CROPPING & SIZE FIX: Contains the image bounds perfectly so fashion models/outfits never cut out */
                      class="max-w-full max-h-full object-contain transition-transform duration-700 group-hover:scale-101 block"
                    />
                  ) : (
                    /* Fallback standard luxury placeholder if image is missing */
                    <div class="w-full h-full flex items-center justify-center text-neutral-300 bg-neutral-50/20 font-serif tracking-widest text-[10px] uppercase">
                      Image Placeholder
                    </div>
                  )}
                </div>

                <div class="space-y-2">
                  {post.entry.categories?.[0] && (
                    <span class="block text-xs font-bold uppercase tracking-widest text-[#bba15c]">
                      {post.entry.categories[0].replace(/-/g, ' ')}
                    </span>
                  )}
                  <h2 class="text-lg md:text-xl font-serif font-light tracking-tight text-neutral-950 leading-tight group-hover:text-neutral-600 transition-colors duration-200">
                    {post.entry.title}
                  </h2>
                  <p class="text-neutral-500 text-[13px] leading-relaxed font-light line-clamp-2">
                    {post.entry.description}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <div class="max-w-7xl mx-auto px-6 py-4">
      <AdSlot slot="header" format="horizontal" />
    </div>

    {secondaryPosts.length > 0 && (
      <section class="border-b border-neutral-200/60 py-16">
        <div class="max-w-7xl mx-auto px-6">
          
          <div class="text-center mb-12 space-y-2">
            <h2 class="text-2xl font-serif tracking-widest uppercase text-neutral-950 font-medium">The Latest</h2>
            <div class="w-12 h-[1px] bg-[#bba15c] mx-auto"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-12">
            {secondaryPosts.map((post) => (
              <PostCard
                title={post.entry.title}
                slug={post.slug}
                description={post.entry.description}
                featuredImage={post.entry.featuredImage}
                publishedDate={post.entry.publishedDate}
                categories={post.entry.categories}
              />
            ))}
          </div>

        </div>
      </section>
    )}

    {activeCategoryWithPosts.map(({ category, posts }) => (
      <section class="border-b border-neutral-200/60 py-16">
        <div class="max-w-7xl mx-auto px-6">

          <div class="text-center mb-12 space-y-2">
            <a href={`/category/${category.slug}/`} class="no-underline hover:opacity-80 transition">
              <h2 class="text-2xl font-serif tracking-widest uppercase text-neutral-950 font-medium">
                {category.entry.name}
              </h2>
            </a>
            <div class="w-12 h-[1px] bg-[#bba15c] mx-auto"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-12">
            {posts.map((post) => (
              <PostCard
                title={post.entry.title}
                slug={post.slug}
                description={post.entry.description}
                featuredImage={post.entry.featuredImage}
                publishedDate={post.entry.publishedDate}
                categories={post.entry.categories}
              />
            ))}
          </div>

        </div>
      </section>
    ))}

    <section class="bg-neutral-950 text-white py-20 px-6">
      <div class="max-w-xl mx-auto text-center space-y-6">
        <span class="text-xs tracking-widest uppercase text-[#bba15c] font-bold">Newsletter</span>
        <h2 class="text-3xl font-serif tracking-tight">Stay in the Loop</h2>
        <p class="text-sm text-neutral-400 font-light leading-relaxed max-w-sm mx-auto">
          Get the latest fashion trends and styling tips delivered straight to your inbox.
        </p>
        <form class="flex flex-col sm:flex-row gap-2 max-w-md mx-auto pt-2">
          <input
            type="email"
            placeholder="Your email address"
            class="flex-1 bg-neutral-900 border border-neutral-800 text-sm px-4 py-3 text-white focus:outline-none focus:border-[#bba15c] transition"
            required
          />
          <button type="submit" class="bg-white text-neutral-950 font-bold uppercase tracking-wider text-xs px-6 py-3 hover:bg-[#bba15c] hover:text-white transition duration-300">
            Subscribe
          </button>
        </form>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
