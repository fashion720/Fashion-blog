---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import {
  getAllPosts,
  getAllCategories,
  getPostsByCategory,
  getSiteSettings,
} from '../lib/keystatic-reader';

const settings = await getSiteSettings();
const allCategories = await getAllCategories();
const parentCategories = allCategories.filter((cat) => !cat.entry.parentCategory);

// All posts sorted by date
const allPosts = await getAllPosts();

// Hero: latest isFeatured post
const featuredPosts = allPosts.filter((p) => p.entry.isFeatured);
const heroPost = featuredPosts[0] ?? allPosts[0];

// Secondary featured (for the 3-card banner strip below hero)
const secondaryPosts = allPosts.filter((p) => p.slug !== heroPost?.slug).slice(0, 3);

// Category sections — latest 3 posts each
const categoryWithPosts = await Promise.all(
  parentCategories.map(async (cat) => {
    const posts = await getPostsByCategory(cat.slug);
    return { category: cat, posts: posts.slice(0, 3) };
  })
);
const activeCategoryWithPosts = categoryWithPosts.filter((c) => c.posts.length > 0);

function img(src?: string) {
  if (!src) return '/images/placeholder.jpg';
  return src.startsWith('/') ? src : `/images/posts/${src}`;
}

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', {
    month: 'long', day: 'numeric', year: 'numeric',
  });
}
---

<Layout title={`${settings.siteName} — ${settings.tagline}`}>
  <Header currentPath="/" />

  <main class="bg-white min-h-screen">

    <!-- ═══════════════════════════════════════════════
         HERO — full-width editorial banner
    ═══════════════════════════════════════════════ -->
    {heroPost && (
      <section class="border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-16">
          <a href={`/posts/${heroPost.slug}`} class="group flex flex-col md:flex-row gap-10 lg:gap-16 items-center">

            <!-- Image -->
            <div class="w-full md:w-1/2 overflow-hidden rounded-sm bg-gray-100 flex-shrink-0">
              <img
                src={img(heroPost.entry.featuredImage)}
                alt={heroPost.entry.title}
                class="w-full h-[340px] md:h-[480px] object-cover object-top
                       transition-transform duration-700 group-hover:scale-[1.03]"
              />
            </div>

            <!-- Text -->
            <div class="w-full md:w-1/2 flex flex-col justify-center">
              {heroPost.entry.categories?.[0] && (
                <p class="text-[10px] font-bold tracking-[0.25em] uppercase text-gray-400 mb-5">
                  {heroPost.entry.categories[0]}
                </p>
              )}
              <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight text-gray-900
                          mb-5 group-hover:text-gray-600 transition-colors duration-300">
                {heroPost.entry.title}
              </h1>
              <p class="text-base lg:text-lg text-gray-500 leading-relaxed mb-6 max-w-lg">
                {heroPost.entry.description}
              </p>
              <div class="flex items-center gap-4">
                <span class="text-xs font-bold uppercase tracking-[0.15em] border-b-2 border-black pb-0.5">
                  Read More
                </span>
                <span class="text-xs text-gray-400">{fmtDate(heroPost.entry.publishedDate)}</span>
              </div>
            </div>

          </a>
        </div>
      </section>
    )}

    <!-- Ad slot -->
    <AdSlot slot="header" format="horizontal" className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6" />

    <!-- ═══════════════════════════════════════════════
         SECONDARY STRIP — 3 cards in a row (like WWW "The Latest")
    ═══════════════════════════════════════════════ -->
    {secondaryPosts.length > 0 && (
      <section class="border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

          <!-- Section header -->
          <div class="flex items-center justify-between mb-8">
            <div class="flex items-center gap-4">
              <h2 class="text-[10px] font-bold tracking-[0.25em] uppercase text-gray-900">The Latest</h2>
              <div class="hidden md:block h-px w-20 bg-gray-200"></div>
            </div>
            <a href="/posts" class="text-[10px] font-bold tracking-[0.2em] uppercase text-gray-400
                                    hover:text-gray-900 border-b border-gray-300 hover:border-gray-900
                                    pb-0.5 transition-colors">
              View All Stories →
            </a>
          </div>

          <!-- Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {secondaryPosts.map((post) => (
              <a href={`/posts/${post.slug}`} class="group block">
                <div class="overflow-hidden rounded-sm bg-gray-100 mb-4">
                  <img
                    src={img(post.entry.featuredImage)}
                    alt={post.entry.title}
                    class="w-full h-52 object-cover object-top
                           transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
                {post.entry.categories?.[0] && (
                  <p class="text-[10px] font-bold tracking-[0.2em] uppercase text-gray-400 mb-2">
                    {post.entry.categories[0]}
                  </p>
                )}
                <h3 class="text-base font-bold text-gray-900 leading-snug mb-2
                            group-hover:text-gray-600 transition-colors">
                  {post.entry.title}
                </h3>
                <p class="text-sm text-gray-500 line-clamp-2 mb-3">{post.entry.description}</p>
                <p class="text-xs text-gray-400">{fmtDate(post.entry.publishedDate)}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══════════════════════════════════════════════
         CATEGORY SECTIONS — WWW style: title + 3 articles
    ═══════════════════════════════════════════════ -->
    {activeCategoryWithPosts.map(({ category, posts }, sectionIdx) => (
      <section class="border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

          <!-- Category header -->
          <div class="flex items-center justify-between mb-8">
            <div class="flex items-center gap-4">
              <h2 class="text-[10px] font-bold tracking-[0.25em] uppercase text-gray-900">
                {category.entry.name}
              </h2>
              <div class="hidden md:block h-px w-20 bg-gray-200"></div>
            </div>
            <a
              href={`/category/${category.slug}/`}
              class="text-[10px] font-bold tracking-[0.2em] uppercase text-gray-400
                     hover:text-gray-900 border-b border-gray-300 hover:border-gray-900
                     pb-0.5 transition-colors whitespace-nowrap"
            >
              Read More {category.entry.name} →
            </a>
          </div>

          <!-- 1 big + 2 small layout (WWW style) -->
          {posts.length === 1 && (
            <div class="max-w-md">
              <a href={`/posts/${posts[0].slug}`} class="group block">
                <div class="overflow-hidden rounded-sm bg-gray-100 mb-4">
                  <img src={img(posts[0].entry.featuredImage)} alt={posts[0].entry.title}
                       class="w-full h-64 object-cover object-top transition-transform duration-500 group-hover:scale-105" />
                </div>
                <h3 class="text-lg font-bold text-gray-900 group-hover:text-gray-600 transition mb-2">
                  {posts[0].entry.title}
                </h3>
                <p class="text-sm text-gray-500 line-clamp-2">{posts[0].entry.description}</p>
              </a>
            </div>
          )}

          {posts.length === 2 && (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              {posts.map((post) => (
                <a href={`/posts/${post.slug}`} class="group block">
                  <div class="overflow-hidden rounded-sm bg-gray-100 mb-4">
                    <img src={img(post.entry.featuredImage)} alt={post.entry.title}
                         class="w-full h-64 object-cover object-top transition-transform duration-500 group-hover:scale-105" />
                  </div>
                  {post.entry.categories?.[0] && (
                    <p class="text-[10px] font-bold tracking-[0.2em] uppercase text-gray-400 mb-2">
                      {post.entry.categories[0]}
                    </p>
                  )}
                  <h3 class="text-base font-bold text-gray-900 group-hover:text-gray-600 transition leading-snug mb-2">
                    {post.entry.title}
                  </h3>
                  <p class="text-sm text-gray-500 line-clamp-2 mb-2">{post.entry.description}</p>
                  <p class="text-xs text-gray-400">{fmtDate(post.entry.publishedDate)}</p>
                </a>
              ))}
            </div>
          )}

          {posts.length >= 3 && (
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
              {posts.slice(0, 3).map((post, i) => (
                <a href={`/posts/${post.slug}`} class="group block">
                  <div class="overflow-hidden rounded-sm bg-gray-100 mb-4">
                    <img
                      src={img(post.entry.featuredImage)}
                      alt={post.entry.title}
                      class={`w-full object-cover object-top transition-transform duration-500 group-hover:scale-105 ${i === 0 ? 'h-72' : 'h-52'}`}
                    />
                  </div>
                  {post.entry.categories?.[0] && (
                    <p class="text-[10px] font-bold tracking-[0.2em] uppercase text-gray-400 mb-2">
                      {post.entry.categories[0]}
                    </p>
                  )}
                  <h3 class="text-base font-bold text-gray-900 group-hover:text-gray-600 transition leading-snug mb-2">
                    {post.entry.title}
                  </h3>
                  <p class="text-sm text-gray-500 line-clamp-2 mb-2">{post.entry.description}</p>
                  <p class="text-xs text-gray-400">{fmtDate(post.entry.publishedDate)}</p>
                </a>
              ))}
            </div>
          )}

        </div>
      </section>
    ))}

    <!-- ═══════════════════════════════════════════════
         NEWSLETTER
    ═══════════════════════════════════════════════ -->
    <section class="bg-gray-50 border-t border-gray-200 py-20">
      <div class="max-w-xl mx-auto px-4 text-center">
        <p class="text-[10px] font-bold tracking-[0.3em] uppercase text-gray-400 mb-3">Newsletter</p>
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Stay in the Loop</h2>
        <p class="text-sm text-gray-500 mb-8 leading-relaxed">
          Get the latest fashion trends and styling tips delivered to your inbox.
        </p>
        <form class="flex gap-3 max-w-md mx-auto">
          <input
            type="email"
            placeholder="Your email address"
            class="flex-1 px-4 py-3 border border-gray-300 text-sm
                   focus:outline-none focus:border-black transition-colors rounded-sm"
            required
          />
          <button
            type="submit"
            class="bg-black text-white px-6 py-3 text-[10px] font-bold tracking-[0.2em]
                   uppercase hover:bg-gray-800 transition-colors rounded-sm whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
