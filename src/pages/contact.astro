---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Contact Us | Outfit Edits";
const pageDescription = "Get in touch with the Outfit Edits team for collaborations, questions, or feedback.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl md:text-4xl font-bold mb-6">Contact Us</h1>

    <div class="prose prose-lg max-w-none">
      <p>
        We would love to hear from you. Whether you have a question about
        one of our posts, a collaboration or partnership idea, or general
        feedback about Outfit Edits, reach out using the details below.
      </p>

      <h2 class="text-2xl font-semibold mt-8 mb-3">Email</h2>
      <p>
        For all inquiries, including collaborations, advertising, and
        general questions, email us at:
        <br />
        <a href="mailto:contact@outfitedits.com" class="underline font-medium">
          contact@outfitedits.com
        </a>
      </p>

      <h2 class="text-2xl font-semibold mt-8 mb-3">Response Time</h2>
      <p>
        We try to respond to all messages within two to three business
        days. For collaboration or sponsorship requests, please include
        as much detail as possible so we can get back to you quickly.
      </p>

      <h2 class="text-2xl font-semibold mt-8 mb-3">Follow Along</h2>
      <p>
        You can also find our latest outfit ideas and updates on
        Pinterest. We regularly post new pins linking back to our guides
        and styling tips.
      </p>
    </div>
  </main>
</Layout>
