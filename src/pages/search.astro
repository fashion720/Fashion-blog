---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getAllPosts } from '../lib/keystatic-reader';

const allPosts = await getAllPosts();

const searchIndex = allPosts.map((post) => ({
  title: post.entry.title,
  description: post.entry.description,
  slug: post.slug,
  image: post.entry.featuredImage ? (post.entry.featuredImage.startsWith('/') ? post.entry.featuredImage : `/images/posts/${post.entry.featuredImage}`) : '/images/placeholder.jpg',
  publishedDate: post.entry.publishedDate,
  categories: post.entry.categories || [],
}));
---

<Layout title="Search Results - Fashion Editorial" description="Search outfit ideas, style guides, and fashion inspiration.">
  <Header currentPath="/search" />

  <main class="min-h-screen bg-[#faf9f6] text-neutral-900 font-sans antialiased">
    
    <!-- Minimalist Dynamic Title Header -->
    <div class="border-b border-neutral-200/60 py-16 text-center space-y-3">
      <p class="text-xs tracking-widest uppercase text-[#bba15c] font-bold">Search Archive</p>
      <h1 id="search-title-text" class="text-2xl md:text-4xl font-serif font-light tracking-wide text-neutral-950 uppercase px-4">
        Search Results
      </h1>
    </div>

    <!-- Clean Results Container (Uses the exact max-7xl width as homepage) -->
    <div class="max-w-7xl mx-auto px-6 py-16">
      <div id="search-results-grid" class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-12 transition-opacity duration-200">
        <!-- Results or placeholder injections via pure vanilla js mapping -->
        <div class="col-span-full text-center py-12 text-neutral-400 font-light text-sm tracking-wide">
          Processing your query...
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script define:vars={{ searchIndex }}>
  const resultsContainer = document.getElementById('search-results-grid');
  const titleText = document.getElementById('search-title-text');

  function runSearch() {
    // 1. Extract query standard key values from URL parameter '?q='
    const urlParams = new URLSearchParams(window.location.search);
    const query = urlParams.get('q') || '';

    if (!query.trim()) {
      titleText.innerText = "Search Results";
      resultsContainer.innerHTML = `
        <div class="col-span-full text-center py-24 text-neutral-400 font-light text-sm tracking-wide">
          <p>No search term provided. Use the header icon to start exploring.</p>
        </div>
      `;
      return;
    }

    // Update editorial page header with searched query text dynamically
    titleText.innerText = `Results for: ${query}`;

    const q = query.toLowerCase().trim();
    const matches = searchIndex.filter((post) =>
      post.title.toLowerCase().includes(q) ||
      post.description.toLowerCase().includes(q)
    );

    if (matches.length === 0) {
      resultsContainer.innerHTML = `
        <div class="col-span-full text-center py-24 text-neutral-400 font-light text-sm tracking-wide">
          <p>No results found matching "${query}". Try exploring another trend.</p>
        </div>
      `;
      return;
    }

    // 2. Render matched elements into the identical luxury magazine grid using custom mapping
    resultsContainer.innerHTML = matches
      .map((post) => {
        const formattedDate = new Date(post.publishedDate).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
        
        const categoryLabel = post.categories.length > 0 
          ? post.categories[0].replace(/-/g, ' ') 
          : '';

        return `
          <article class="post-card group w-full bg-transparent">
            <a href="/posts/${post.slug}" class="block no-underline">
              <div class="overflow-hidden aspect-[3/4] w-full block">
                <img
                  src="${post.image}"
                  alt="${post.title}"
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-102 block"
                />
              </div>
              <div class="text-left pt-3 px-0">
                ${categoryLabel ? `<span class="block text-[11px] font-bold uppercase tracking-widest text-[#bba15c] mb-1">${categoryLabel}</span>` : ''}
                <h3 class="text-lg font-medium tracking-tight text-neutral-900 mb-1.5 group-hover:text-neutral-600 transition-colors duration-200 leading-tight">
                  ${post.title}
                </h3>
                <p class="text-[13px] font-normal text-neutral-500 leading-relaxed line-clamp-2 mb-2">
                  ${post.description}
                </p>
                <div class="text-[10px] uppercase tracking-widest text-neutral-400">
                  <time>${formattedDate}</time>
                </div>
              </div>
            </a>
          </article>
        `;
      })
      .join('');
  }

  // Trigger auto evaluation on page mount
  runSearch();
</script>

<style is:global>
  /* Ensuring line clamps inside string literal template additions behave safely */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
