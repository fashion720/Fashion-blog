---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getAllPosts } from '../lib/keystatic-reader';

const allPosts = await getAllPosts();

const searchIndex = allPosts.map((post) => ({
  title: post.entry.title,
  description: post.entry.description,
  slug: post.slug,
  image: post.entry.featuredImage ? `/images/posts/${post.entry.featuredImage}` : '/images/og/default.jpg',
}));
---

<Layout title="Search - Fashion Blog" description="Search outfit ideas, style guides, and fashion inspiration.">
  <Header currentPath="/search" />

  <main class="min-h-screen container mx-auto px-4 py-12 max-w-3xl">
    <h1 class="text-4xl font-extrabold mb-6">Search</h1>

    <div class="relative mb-10">
      <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="Search outfit ideas, style tips..."
        class="w-full pl-12 pr-4 py-4 text-lg border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-black"
        autofocus
      />
    </div>

    <div id="search-results" class="flex flex-col gap-4">
      <p id="search-placeholder" class="text-gray-500 text-center py-8">Start typing to search posts.</p>
    </div>
  </main>

  <Footer />
</Layout>

<script define:vars={{ searchIndex }}>
  const input = document.getElementById('search-input');
  const resultsContainer = document.getElementById('search-results');

  function renderResults(query) {
    if (!query.trim()) {
      resultsContainer.innerHTML = '<p class="text-gray-500 text-center py-8">Start typing to search posts.</p>';
      return;
    }

    const q = query.toLowerCase();
    const matches = searchIndex.filter((post) =>
      post.title.toLowerCase().includes(q) ||
      post.description.toLowerCase().includes(q)
    );

    if (matches.length === 0) {
      resultsContainer.innerHTML = `<p class="text-gray-500 text-center py-8">No results for "${query}". Try a different search.</p>`;
      return;
    }

    resultsContainer.innerHTML = matches
      .map((post) => `
        <a href="/posts/${post.slug}/" class="flex gap-4 p-4 rounded-xl border border-gray-200 hover:shadow-md transition">
          <img src="${post.image}" alt="${post.title}" width="96" height="96" loading="lazy" class="w-24 h-24 object-cover rounded-lg flex-shrink-0" />
          <div>
            <h3 class="font-bold text-lg mb-1">${post.title}</h3>
            <p class="text-gray-600 text-sm line-clamp-2">${post.description}</p>
          </div>
        </a>
      `)
      .join('');
  }

  let debounceTimer;
  input?.addEventListener('input', (e) => {
    clearTimeout(debounceTimer);
    const query = e.target.value;
    debounceTimer = setTimeout(() => renderResults(query), 150);
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
