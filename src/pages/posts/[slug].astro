---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import SocialShare from '../../components/SocialShare.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import PopularPosts from '../../components/PopularPosts.astro';
import { marked } from 'marked';
import { getAllPosts, getAuthorBySlug } from '../../lib/keystatic-reader';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { entry } = post;

const rawContent = (await entry.content()) as string;
const renderedContent = marked(rawContent ?? '');
const author = entry.author ? await getAuthorBySlug(entry.author) : null;

// 👑 FALLBACK UTILITY: Extracts the first available image strings for assets parsing
function getPostImage(post: any) {
  if (post.entry.sections && post.entry.sections[0]?.image) return post.entry.sections[0].image;
  if (post.entry.images && post.entry.images[0]) return post.entry.images[0];
  return '/images/og/default.jpg';
}

const resolvedImg = getPostImage(post);
const featuredImage = resolvedImg.startsWith('/') ? resolvedImg : `/images/posts/${resolvedImg}`;
const postUrl = new URL(`/posts/${post.slug}/`, Astro.site).toString();

const formattedDate = entry.publishedDate
  ? new Date(entry.publishedDate).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';

// 👑 AUTOMATIC TEXT EXTRACTOR FOR SEO METADATA DESC
function getPostDescription(rawContent: string, length = 160) {
  if (!rawContent) return "Explore contemporary style and curated fashion insights inside this editorial.";
  const cleanText = rawContent
    .replace(/[#*_`~]/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/^[-\s]*\n/gm, '')
    .trim();
  return cleanText.length > length ? `${cleanText.substring(0, length)}...` : cleanText;
}

const seoDescription = getPostDescription(rawContent, 160);
const isMonetized = false;
---

<Layout
  title={`${entry.title} — Fashion Editorial`}
  description={seoDescription}
  image={featuredImage}
  article={true}
  publishedTime={entry.publishedDate}
  modifiedTime={entry.updatedDate}
  author={author?.name}
  tags={entry.tags}
>
  <ReadingProgress />
  <Header currentPath={`/posts/${post.slug}`} />

  <main class="min-h-screen bg-[#F8F6F2] text-neutral-900 font-sans antialiased max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
    
    <article class="w-full">
      
      {/* 📋 NARROW STRUCTURE WRAPPER: Title Header block */}
      <header class="text-center mb-10 md:mb-14 space-y-4 max-w-3xl mx-auto">
        {entry.categories && entry.categories.length > 0 && (
          <div class="flex justify-center gap-x-4 gap-y-1 items-center">
            {entry.categories.map((cat: string) => (
              <a href={`/category/${cat}/`} class="text-[10px] font-bold uppercase tracking-[0.25em] text-[#bba15c] hover:opacity-80 transition no-underline">
                {cat.replace(/-/g, ' ')}
              </a>
            ))}
          </div>
        )}
        
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-5.5xl font-serif font-light tracking-tight text-neutral-950 leading-[1.15] max-w-2xl mx-auto">
          {entry.title}
        </h1>
        
        <div class="flex items-center justify-center gap-3 text-[10px] uppercase tracking-[0.2em] text-neutral-400 font-sans pt-2">
          {author && <span class="font-bold text-neutral-800 tracking-widest">{author.name}</span>}
          {author && <span class="text-neutral-300">•</span>}
          <time datetime={entry.publishedDate}>{formattedDate}</time>
        </div>
        
        <div class="w-16 h-[1px] bg-[#bba15c] mx-auto pt-4"></div>
      </header>

      {/* 👑 WIDE STRUCTURE BANNER LAYER */}
      {featuredImage && (
        <div class="w-full max-w-4xl mx-auto mb-12 overflow-hidden bg-white p-4 border border-neutral-200/30 shadow-sm/5 rounded-sm">
          <div class="overflow-hidden w-full h-auto rounded-[1px] relative block">
            <img
              src={featuredImage}
              alt={entry.title}
              class="w-full h-auto block select-none max-h-[65vh] md:max-h-[70vh] object-cover"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>
        </div>
      )}

      {/* 📖 NARROW READING MATRIX */}
      <div class="max-w-2xl sm:max-w-3xl mx-auto">
        <div class="prose prose-neutral max-w-none fashion-prose-content" set:html={renderedContent} />

        {/* 💸 IN-CONTENT SPONSORED PANEL BUFFER MAP */}
        {isMonetized && (
          <div class="my-12 p-6 bg-white border border-neutral-200/30 shadow-sm/5 rounded-sm text-center relative w-full">
            <span class="absolute -top-2.5 left-4 bg-[#F8F6F2] px-2 text-[9px] font-bold uppercase tracking-widest text-neutral-400">Sponsored Content</span>
            <AdSlot slot="in-content" format="horizontal" />
          </div>
        )}

        {/* ✉️ SHARING ACTION REGISTRY DRAWER */}
        <div class="border-t border-b border-neutral-200/40 py-5 my-10 flex items-center justify-between">
          <span class="text-[10px] uppercase tracking-[0.2em] text-neutral-400 font-bold">Share This Article</span>
          <SocialShare
            title={entry.title}
            description={entry.description}
            url={postUrl}
            image={new URL(featuredImage, Astro.site).toString()}
          />
        </div>

        {/* ✍️ AUTHOR PROFILE EDITORIAL MODULE CARD */}
        {author && (
          <div class="mt-12 p-6 bg-white border border-neutral-200/30 shadow-sm/5 rounded-sm flex flex-col sm:flex-row items-center sm:items-start gap-5 text-center sm:text-left">
            {author.avatar && (
              <img
                src={`/images/authors/${author.avatar}`}
                alt={author.name}
                width="64"
                height="64"
                loading="lazy"
                decoding="async"
                class="w-14 h-14 rounded-full object-cover border border-neutral-100 shrink-0 select-none pointer-events-none"
              />
            )}
            <div class="space-y-1">
              <p class="font-serif text-base font-light text-neutral-950">{author.name}</p>
              <p class="text-xs text-neutral-500 font-light leading-relaxed max-w-xl">{author.bio}</p>
            </div>
          </div>
        )}
      </div>

    </article>

    <section class="mt-16 pt-12 border-t border-neutral-200/40 max-w-7xl mx-auto">
      <div class="text-center mb-10 md:mb-14 space-y-2">
        <h3 class="text-[11px] font-sans tracking-[0.35em] uppercase text-neutral-950 font-bold">Trending Now</h3>
        <div class="w-12 h-[1px] bg-[#bba15c] mx-auto"></div>
      </div>
      <PopularPosts />
    </section>

  </main>

  <Footer />
</Layout>

<script define:vars={{ postUrl, postTitle: entry.title }}>
  document.addEventListener('DOMContentLoaded', () => {
    const contentDiv = document.querySelector('.fashion-prose-content');
    if (!contentDiv) return;

    const images = contentDiv.querySelectorAll('img');

    images.forEach((img) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'img-pin-wrapper my-12 block w-full bg-white p-4 border border-neutral-200/30 shadow-sm/5 rounded-sm';

      img.parentNode.insertBefore(wrapper, img);
      wrapper.appendChild(img);

      img.style.margin = '0';
      img.style.width = '100%';
      img.style.display = 'block';
      img.classList.add('rounded-[1px]');

      const imgSrc = img.getAttribute('src');
      const absoluteImgSrc = imgSrc?.startsWith('http')
        ? imgSrc
        : window.location.origin + imgSrc;

      const pinBtn = document.createElement('a');
      pinBtn.href = `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(postUrl)}&media=${encodeURIComponent(absoluteImgSrc)}&description=${encodeURIComponent(img.alt || postTitle)}`;
      pinBtn.target = '_blank';
      pinBtn.rel = 'noopener noreferrer';
      pinBtn.className = 'pin-save-btn';
      pinBtn.innerHTML = `
        <svg width="13" height="14" viewBox="0 0 24 24" fill="#E60023"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.992 3.993-.283 1.194.599 2.169 1.775 2.169 2.13 0 3.769-2.247 3.769-5.491 0-2.871-2.063-4.878-5.01-4.878-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.179 23.774 10.551 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
        Save to Pinterest
      `;

      wrapper.appendChild(pinBtn);
    });
  });
</script>

<style is:global>
  .fashion-prose-content {
    max-width: 100% !important;
  }
  .fashion-prose-content p {
    margin-top: 0 !important;
    margin-bottom: 1.85rem !important;
    font-size: 15px !important;
    line-height: 1.9 !important;
    color: #333333 !important;
    font-weight: 300 !important;
    letter-spacing: 0.01em !important;
  }
  
  .fashion-prose-content > p:first-of-type::first-letter {
    font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif !important;
    float: left;
    font-size: 3.85rem;
    line-height: 1;
    margin-top: 0.25rem;
    margin-right: 0.75rem;
    font-weight: 300;
    color: #0a0a0a;
  }
  
  .fashion-prose-content h2, 
  .fashion-prose-content h3 {
    font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif !important;
    font-weight: 300 !important;
    color: #0a0a0a !important;
    margin-top: 3.5rem !important;
    margin-bottom: 1.15rem !important;
    letter-spacing: -0.01em !important;
    line-height: 1.3 !important;
  }
  .fashion-prose-content h2 {
    font-size: 1.85rem !important;
    border-bottom: 1px solid rgba(229, 231, 235, 0.4);
    padding-bottom: 0.6rem;
  }
  .fashion-prose-content h3 {
    font-size: 1.45rem !important;
  }
  .fashion-prose-content a {
    color: #bba15c !important;
    text-decoration-line: underline !important;
    text-underline-offset: 4px;
    font-weight: 400 !important;
  }
  .fashion-prose-content ul, .fashion-prose-content ol {
    margin-bottom: 1.85rem !important;
    padding-left: 1.25rem !important;
    color: #333333 !important;
    font-weight: 300 !important;
  }
  .fashion-prose-content li {
    margin-bottom: 0.65rem !important;
    font-size: 15px !important;
    line-height: 1.8 !important;
  }

  .img-pin-wrapper .pin-save-btn {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 8px !important;
    width: 100% !important;
    margin-top: 12px !important;
    padding: 11px 0 !important;
    background: #fff !important;
    border: 1px solid #E60023 !important;
    color: #E60023 !important;
    font-size: 10.5px !important;
    font-weight: 700 !important;
    letter-spacing: 0.2em !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    cursor: pointer !important;
    transition: all 0.3s ease !important;
    font-family: sans-serif !important;
  }

  .img-pin-wrapper .pin-save-btn:hover {
    background: #E60023 !important;
    color: #fff !important;
  }

  .img-pin-wrapper .pin-save-btn:hover svg {
    fill: #fff !important;
  }
</style>
