---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import SocialShare from '../../components/SocialShare.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import PopularPosts from '../../components/PopularPosts.astro';
import { marked } from 'marked';
import { getAllPosts, getAuthorBySlug } from '../../lib/keystatic-reader';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { entry } = post;

const rawContent = await entry.content() as string;
const renderedContent = marked(rawContent ?? '');
const author = entry.author ? await getAuthorBySlug(entry.author) : null;

const featuredImage = entry.featuredImage
  ? (entry.featuredImage.startsWith('/') ? entry.featuredImage : `/images/posts/${entry.featuredImage}`)
  : '/images/og/default.jpg';
const postUrl = new URL(`/posts/${post.slug}/`, Astro.site).toString();

const formattedDate = entry.publishedDate
  ? new Date(entry.publishedDate).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';
---

<Layout
  title={`${entry.title} - Fashion Editorial`}
  description={entry.description}
  image={featuredImage}
  article={true}
  publishedTime={entry.publishedDate}
  modifiedTime={entry.updatedDate}
  author={author?.name}
  tags={entry.tags}
>
  <ReadingProgress />
  <Header currentPath={`/posts/${post.slug}`} />

  {/* 🛠️ PREMIUM GRID WRAPPER: Now mirrors index/category max-w-7xl symmetry */}
  <main class="max-w-7xl mx-auto px-6 py-12 bg-[#faf9f6]">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-x-16 gap-y-12 items-start">
      
      {/* LEFT COLUMN: Main Article Body */}
      <article class="w-full overflow-hidden">
        
        {/* Editorial Header */}
        <header class="mb-8 space-y-4">
          {entry.categories && entry.categories.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {entry.categories.map((cat: string) => (
                <a href={`/category/${cat}/`} class="text-[11px] font-bold uppercase tracking-widest text-[#bba15c] hover:opacity-80 transition no-underline">
                  {cat.replace(/-/g, ' ')}
                </a>
              ))}
            </div>
          )}
          
          <h1 class="text-3xl md:text-5xl font-serif font-light tracking-tight text-neutral-950 leading-[1.15]">
            {entry.title}
          </h1>
          
          <div class="flex items-center gap-3 text-xs uppercase tracking-widest text-neutral-400 font-sans pt-1">
            {author && <span class="font-bold text-neutral-800">{author.name}</span>}
            {author && <span>•</span>}
            <time datetime={entry.publishedDate}>{formattedDate}</time>
          </div>
          
          <div class="w-full h-[1px] bg-neutral-200/60 pt-2"></div>
        </header>

        {/* 🛠️ HIGH-END FEATURED IMAGE: Fluid layout without forced tech-blog corner rounds */}
        {entry.featuredImage && (
          <div class="w-full mb-10 overflow-hidden bg-neutral-100 rounded-sm">
            <img
              src={featuredImage}
              alt={entry.title}
              class="w-full h-auto object-contain block max-h-[75vh]"
              loading="eager"
              decoding="async"
            />
          </div>
        )}

        {/* 🛠️ TYPOGRAPHY TUNING: Tailored prose style for fashion content readability */}
        <div class="prose prose-neutral max-w-none fashion-prose-content text-[15px] md:text-[16px] text-neutral-800 leading-relaxed font-light tracking-wide" set:html={renderedContent} />

        {/* In-Content Ads Slot Area */}
        <AdSlot slot="in-content" format="horizontal" className="my-12" />

        {/* Share Section Wrapper */}
        <div class="border-t border-b border-neutral-200/60 py-6 my-10 flex items-center justify-between">
          <span class="text-xs uppercase tracking-widest text-neutral-400 font-bold">Share This Article</span>
          <SocialShare
            title={entry.title}
            description={entry.description}
            url={postUrl}
            image={new URL(featuredImage, Astro.site).toString()}
          />
        </div>

        {/* Editorial Author Bio Card */}
        {author && (
          <div class="mt-12 p-6 bg-white border border-neutral-200/40 rounded-sm flex flex-col sm:flex-row items-center sm:items-start gap-5 text-center sm:text-left">
            {author.avatar && (
              <img
                src={`/images/authors/${author.avatar}`}
                alt={author.name}
                width="64"
                height="64"
                loading="lazy"
                decoding="async"
                class="w-16 h-16 rounded-full object-cover border border-neutral-100 shrink-0"
              />
            )}
            <div class="space-y-1">
              <p class="font-serif text-base font-medium text-neutral-900">{author.name}</p>
              <p class="text-xs text-neutral-500 font-light leading-relaxed max-w-xl">{author.bio}</p>
            </div>
          </div>
        )}
      </article>

      {/* 🛠️ RIGHT COLUMN: Premium Sidebar with Sticky Scroll Context */}
      <aside class="w-full flex flex-col gap-10 lg:sticky lg:top-24">
        <AdSlot slot="sidebar" format="rectangle" className="m-0" />
        
        <div class="bg-white p-6 border border-neutral-200/40 rounded-sm space-y-6">
          <div class="space-y-1.5 border-b border-neutral-100 pb-3">
            <h3 class="text-xs font-bold tracking-widest uppercase text-neutral-900">Trending Now</h3>
            <div class="w-8 h-[1px] bg-[#bba15c]"></div>
          </div>
          <PopularPosts />
        </div>

        <AdSlot slot="sidebar" format="vertical" className="m-0" />
      </aside>
      
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* ⚡ CUSTOM TYPOGRAPHY OVERRIDES FOR AD REVENUE BLOGS */
  .fashion-prose-content p {
    margin-bottom: 1.75rem !important;
    font-size: 16px;
    line-height: 1.8;
  }
  .fashion-prose-content h2, 
  .fashion-prose-content h3 {
    font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif !important;
    font-weight: 400 !important;
    color: #0a0a0a !important;
    margin-top: 2.5rem !important;
    margin-bottom: 1rem !important;
    letter-spacing: -0.02em !important;
  }
  .fashion-prose-content h2 {
    font-size: 1.75rem !important;
    border-b: 1px solid #f5f5f5;
    padding-bottom: 0.5rem;
  }
  .fashion-prose-content h3 {
    font-size: 1.4rem !important;
  }
  .fashion-prose-content img {
    border-radius: 2px !important;
    margin: 2.5rem auto !important;
    box-shadow: 0 4px 20px -10px rgba(0,0,0,0.05);
  }
  .fashion-prose-content a {
    color: #bba15c !important;
    text-decoration-line: underline !important;
    text-underline-offset: 4px;
  }
</style>
