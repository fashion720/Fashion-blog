---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import SocialShare from '../../components/SocialShare.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import PopularPosts from '../../components/PopularPosts.astro';
import { marked } from 'marked';
import { getAllPosts, getAuthorBySlug } from '../../lib/keystatic-reader';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { entry } = post;

const rawContent = await entry.content() as string;
const renderedContent = marked(rawContent ?? '');
const author = entry.author ? await getAuthorBySlug(entry.author) : null;

const featuredImage = entry.featuredImage
  ? (entry.featuredImage.startsWith('/') ? entry.featuredImage : `/images/posts/${entry.featuredImage}`)
  : '/images/og/default.jpg';
const postUrl = new URL(`/posts/${post.slug}/`, Astro.site).toString();

const formattedDate = entry.publishedDate
  ? new Date(entry.publishedDate).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';

// 💸 MONETIZATION SECURE FLAG
const isMonetized = false;
---

<Layout
  title={`${entry.title} — Fashion Editorial`}
  description={entry.description}
  image={featuredImage}
  article={true}
  publishedTime={entry.publishedDate}
  modifiedTime={entry.updatedDate}
  author={author?.name}
  tags={entry.tags}
>
  <ReadingProgress />
  <Header currentPath={`/posts/${post.slug}`} />

  <main class="min-h-screen bg-[#faf9f6] text-neutral-900 font-sans antialiased max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
    
    <article class="w-full max-w-3xl mx-auto">
      
      {/* 📋 CENTER-STAGED BRAND ARCHIVE TOP META HEADER */}
      <header class="text-center mb-10 md:mb-14 space-y-4">
        {entry.categories && entry.categories.length > 0 && (
          <div class="flex justify-center gap-x-4 gap-y-1 items-center">
            {entry.categories.map((cat: string) => (
              <a href={`/category/${cat}/`} class="text-[10px] font-bold uppercase tracking-[0.25em] text-[#bba15c] hover:opacity-80 transition no-underline">
                {cat.replace(/-/g, ' ')}
              </a>
            ))}
          </div>
        )}
        
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-serif font-light tracking-tight text-neutral-950 leading-[1.15] max-w-2xl mx-auto">
          {entry.title}
        </h1>
        
        <div class="flex items-center justify-center gap-3 text-[10px] uppercase tracking-[0.2em] text-neutral-400 font-sans pt-2">
          {author && <span class="font-bold text-neutral-800 tracking-widest">{author.name}</span>}
          {author && <span class="text-neutral-300">•</span>}
          <time datetime={entry.publishedDate}>{formattedDate}</time>
        </div>
        
        <div class="w-16 h-[1px] bg-[#bba15c] mx-auto pt-4"></div>
      </header>

      {/* 👑 FEATURED IMAGE — NO PINTEREST BUTTON */}
      {entry.featuredImage && (
        <div class="w-full mb-12 overflow-hidden bg-neutral-100 rounded-sm">
          <img
            src={featuredImage}
            alt={entry.title}
            class="w-full h-auto object-cover block max-h-[65vh] md:max-h-[70vh] select-none"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      )}

      {/* 📖 ULTRA-CLEAN ENHANCED TYPOGRAPHY STREAM */}
      <div class="prose prose-neutral max-w-none fashion-prose-content" set:html={renderedContent} />

      {/* 💸 IN-CONTENT SPONSORED PANEL BUFFER MAP */}
      {isMonetized && (
        <div class="my-12 p-6 bg-neutral-50/80 border border-neutral-200/40 rounded-sm text-center relative max-w-5xl mx-auto">
          <span class="absolute -top-2.5 left-4 bg-[#faf9f6] px-2 text-[9px] font-bold uppercase tracking-widest text-neutral-400">Sponsored Content</span>
          <AdSlot slot="in-content" format="horizontal" />
        </div>
      )}

      {/* ✉️ SHARING ACTION REGISTRY DRAWER */}
      <div class="border-t border-b border-neutral-200/50 py-5 my-10 flex items-center justify-between">
        <span class="text-[10px] uppercase tracking-[0.2em] text-neutral-400 font-bold">Share This Article</span>
        <SocialShare
          title={entry.title}
          description={entry.description}
          url={postUrl}
          image={new URL(featuredImage, Astro.site).toString()}
        />
      </div>

      {/* ✍️ AUTHOR PROFILE EDITORIAL MODULE CARD */}
      {author && (
        <div class="mt-12 p-6 bg-white border border-neutral-200/40 rounded-sm flex flex-col sm:flex-row items-center sm:items-start gap-5 text-center sm:text-left">
          {author.avatar && (
            <img
              src={`/images/authors/${author.avatar}`}
              alt={author.name}
              width="64"
              height="64"
              loading="lazy"
              decoding="async"
              class="w-14 h-14 rounded-full object-cover border border-neutral-100 shrink-0 select-none pointer-events-none"
            />
          )}
          <div class="space-y-1">
            <p class="font-serif text-base font-light text-neutral-950">{author.name}</p>
            <p class="text-xs text-neutral-500 font-light leading-relaxed max-w-xl">{author.bio}</p>
          </div>
        </div>
      )}
    </article>

    <section class="mt-16 pt-12 border-t border-neutral-200/60 max-w-7xl mx-auto">
      <div class="text-center mb-10 md:mb-14 space-y-2">
        <h3 class="text-xs font-serif tracking-[0.3em] uppercase text-neutral-950 font-medium">Trending Now</h3>
        <div class="w-12 h-[1px] bg-[#bba15c] mx-auto"></div>
      </div>
      <PopularPosts />
    </section>

  </main>

  <Footer />
</Layout>

<script define:vars={{ postUrl, postTitle: entry.title }}>
  document.addEventListener('DOMContentLoaded', () => {
    const contentDiv = document.querySelector('.fashion-prose-content');
    if (!contentDiv) return;

    const images = contentDiv.querySelectorAll('img');

    images.forEach((img) => {
      // Wrapper div — image + button dono ke liye
      const wrapper = document.createElement('div');
      wrapper.className = 'img-pin-wrapper my-10 block w-full';

      img.parentNode.insertBefore(wrapper, img);
      wrapper.appendChild(img);

      img.style.margin = '0';
      img.style.width = '100%';
      img.style.display = 'block';

      const imgSrc = img.getAttribute('src');
      const absoluteImgSrc = imgSrc?.startsWith('http')
        ? imgSrc
        : window.location.origin + imgSrc;

      // Pinterest Save button — image ke NEECHE
      const pinBtn = document.createElement('a');
      pinBtn.href = `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(postUrl)}&media=${encodeURIComponent(absoluteImgSrc)}&description=${encodeURIComponent(img.alt || postTitle)}`;
      pinBtn.target = '_blank';
      pinBtn.rel = 'noopener noreferrer';
      pinBtn.className = 'pin-save-btn';
      pinBtn.innerHTML = `
        <svg width="14" height="14" viewBox="0 0 24 24" fill="#E60023"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.992 3.993-.283 1.194.599 2.169 1.775 2.169 2.13 0 3.769-2.247 3.769-5.491 0-2.871-2.063-4.878-5.01-4.878-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.179 23.774 10.551 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
        Save to Pinterest
      `;

      wrapper.appendChild(pinBtn);
    });
  });
</script>

<style is:global>
  .fashion-prose-content {
    max-width: 100% !important;
  }
  .fashion-prose-content p {
    margin-top: 0 !important;
    margin-bottom: 1.75rem !important;
    font-size: 15px !important;
    line-height: 1.85 !important;
    color: #333333 !important;
    font-weight: 300 !important;
    letter-spacing: 0.01em !important;
  }
  
  /* 👑 LARGE DROP-CAPS STYLE FOR FIRST EDITORIAL PARAGRAPH */
  .fashion-prose-content > p:first-of-type::first-letter {
    font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif !important;
    float: left;
    font-size: 3.75rem;
    line-height: 1;
    margin-top: 0.25rem;
    margin-right: 0.65rem;
    font-weight: 300;
    color: #0a0a0a;
  }
  
  .fashion-prose-content h2, 
  .fashion-prose-content h3 {
    font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif !important;
    font-weight: 300 !important;
    color: #0a0a0a !important;
    margin-top: 3rem !important;
    margin-bottom: 1rem !important;
    letter-spacing: -0.01em !important;
    line-height: 1.3 !important;
  }
  .fashion-prose-content h2 {
    font-size: 1.8rem !important;
    border-bottom: 1px solid #e5e7eb;
    padding-bottom: 0.5rem;
  }
  .fashion-prose-content h3 {
    font-size: 1.4rem !important;
  }
  .fashion-prose-content a {
    color: #bba15c !important;
    text-decoration-line: underline !important;
    text-underline-offset: 4px;
    font-weight: 400 !important;
  }
  .fashion-prose-content ul, .fashion-prose-content ol {
    margin-bottom: 1.75rem !important;
    padding-left: 1.25rem !important;
    color: #333333 !important;
    font-weight: 300 !important;
  }
  .fashion-prose-content li {
    margin-bottom: 0.65rem !important;
    font-size: 15px !important;
    line-height: 1.75 !important;
  }

  /* Pinterest save button — image ke neeche permanent */
  .img-pin-wrapper .pin-save-btn {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 7px !important;
    width: 100% !important;
    padding: 10px 0 !important;
    background: #fff !important;
    border: 1.5px solid #E60023 !important;
    color: #E60023 !important;
    font-size: 11px !important;
    font-weight: 700 !important;
    letter-spacing: 0.15em !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    cursor: pointer !important;
    transition: background 0.2s ease, color 0.2s ease !important;
    font-family: sans-serif !important;
  }

  .img-pin-wrapper .pin-save-btn:hover {
    background: #E60023 !important;
    color: #fff !important;
  }

  .img-pin-wrapper .pin-save-btn:hover svg {
    fill: #fff !important;
  }
</style>
