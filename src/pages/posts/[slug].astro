---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getAllPosts } from '../../lib/keystatic-reader';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

// Content ko render karne ke liye component nikaalna
const { Content } = await post.entry.content;

// 👑 FALLBACK UTILITY: Agar explicit image na ho toh pehli image nikalna
function getPostImage(post: any) {
  if (post.entry.sections && post.entry.sections[0]?.image) return post.entry.sections[0].image;
  if (post.entry.images && post.entry.images[0]) return post.entry.images[0];
  return '/images/placeholder.jpg';
}

// 👑 AUTOMATIC TEXT EXTRACTOR: MDX content se shuruati 160 characters nikalna SEO Meta Description ke liye
async function getPostDescription(post: any, length = 160) {
  const rawContent = await post.entry.content() as string;
  if (!rawContent) return "Explore contemporary style and curated fashion insights inside this editorial.";
  
  const cleanText = rawContent
    .replace(/[#*_`~]/g, '') // Markdown syntax saaf karna
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // Links text rakhna, URL urana
    .replace(/^[-\s]*\n/gm, '') // Linebreaks khatam karna
    .trim();

  return cleanText.length > length ? `${cleanText.substring(0, length)}...` : cleanText;
}

// Meta description ke liye automatic text generate karna
const seoDescription = await getPostDescription(post, 160);
const postImage = getPostImage(post);
---

<Layout 
  title={`${post.entry.title} — Fashion Editorial`}
  description={seoDescription}
>
  <Header currentPath="/posts" />

  <main class="bg-[#F8F6F2] min-h-screen font-sans antialiased text-neutral-900 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-8">
    
    <article class="space-y-6">
      <header class="space-y-4 text-center py-6">
        {post.entry.categories?.[0] && (
          <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-[#bba15c] block">
            {post.entry.categories[0].replace(/-/g, ' ')}
          </span>
        )}
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-serif font-light tracking-tight text-neutral-950 leading-[1.2] max-w-3xl mx-auto">
          {post.entry.title}
        </h1>
        
        <div class="flex items-center justify-center space-x-2 text-xs text-neutral-400 font-light pt-2">
          <span>By {post.entry.author || 'Editorial Team'}</span>
          <span>•</span>
          <span>{post.entry.publishedDate}</span>
        </div>
      </header>

      <div class="w-full aspect-[16/9] md:aspect-[21/9] overflow-hidden bg-white p-2 border border-neutral-200/20 shadow-sm rounded-sm">
        <img 
          src={postImage.startsWith('/') ? postImage : `/images/posts/${postImage}`}
          alt={post.entry.title}
          class="w-full h-full object-cover rounded-[1px]"
        />
      </div>

      <div class="prose prose-neutral max-w-none pt-8 md:pt-12 text-neutral-800 leading-relaxed font-light text-[15px] sm:text-base prose-headings:font-serif prose-headings:font-light prose-a:text-[#bba15c] prose-img:rounded-sm prose-img:border prose-img:border-neutral-200/30">
        <Content />
      </div>

    </article>
  </main>

  <Footer />
</Layout>
