---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="About Us | Fashion Editorial" 
  description="Discover the story behind Fashion Editorial, our mission, and our approach to premium editorial fashion content."
>
  <Header currentPath="/about" />

  <main class="max-w-4xl mx-auto px-4 md:px-6 py-16 md:py-24">
    <!-- Page Header -->
    <div class="mb-16 md:mb-20">
      <h1 class="text-4xl md:text-5xl font-light tracking-wide mb-6 text-black">
        About Fashion Editorial
      </h1>
      <p class="text-sm md:text-base text-gray-600 font-light leading-relaxed">
        A curated platform exploring contemporary fashion, timeless style principles, and the cultural narratives that shape our wardrobe choices.
      </p>
    </div>

    <!-- Main Content -->
    <article class="space-y-10 md:space-y-14">
      <!-- Our Mission Section -->
      <section>
        <h2 class="text-3xl md:text-4xl font-light tracking-wide mb-6 text-black">
          Our Mission
        </h2>
        <p class="text-base md:text-lg text-gray-700 font-light leading-relaxed mb-4">
          Fashion Editorial is dedicated to creating high-quality, thoughtful content for those who appreciate the intersection of style, culture, and design. We believe fashion is more than trends—it's a form of expression, identity, and creativity.
        </p>
        <p class="text-base md:text-lg text-gray-700 font-light leading-relaxed">
          Our editorial approach prioritizes authenticity, accessibility, and inspiration. We curate articles, guides, and recommendations that serve both aspiring fashion enthusiasts and experienced stylists seeking fresh perspectives.
        </p>
      </section>

      <!-- What We Offer Section -->
      <section>
        <h2 class="text-3xl md:text-4xl font-light tracking-wide mb-6 text-black">
          What We Offer
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
          <div>
            <h3 class="text-xl font-light tracking-wide mb-3 text-black">Editorial Content</h3>
            <p class="text-gray-700 font-light leading-relaxed">
              In-depth articles exploring fashion trends, styling techniques, seasonal collections, and the stories behind iconic designers and brands.
            </p>
          </div>
          <div>
            <h3 class="text-xl font-light tracking-wide mb-3 text-black">Curated Guides</h3>
            <p class="text-gray-700 font-light leading-relaxed">
              Practical styling guides, wardrobe essentials, outfit combinations, and fashion tips designed to elevate your personal style.
            </p>
          </div>
          <div>
            <h3 class="text-xl font-light tracking-wide mb-3 text-black">Trend Analysis</h3>
            <p class="text-gray-700 font-light leading-relaxed">
              Thoughtful commentary on emerging fashion movements, runway highlights, and the cultural moments that define contemporary style.
            </p>
          </div>
          <div>
            <h3 class="text-xl font-light tracking-wide mb-3 text-black">Recommendations</h3>
            <p class="text-gray-700 font-light leading-relaxed">
              Carefully selected product recommendations and brand partnerships that align with our editorial values and aesthetic.
            </p>
          </div>
        </div>
      </section>

      <!-- Our Approach Section -->
      <section>
        <h2 class="text-3xl md:text-4xl font-light tracking-wide mb-6 text-black">
          Our Approach
        </h2>
        <div class="space-y-5">
          <div class="pb-5 border-b border-gray-200">
            <h3 class="text-lg font-light tracking-wide mb-2 text-black">Authenticity First</h3>
            <p class="text-gray-700 font-light leading-relaxed">
              We maintain editorial integrity by recommending only products and brands we genuinely believe in, regardless of commercial partnerships.
            </p>
          </div>
          <div class="pb-5 border-b border-gray-200">
            <h3 class="text-lg font-light tracking-wide mb-2 text-black">Inclusive Perspective</h3>
            <p class="text-gray-700 font-light leading-relaxed">
              Fashion is for everyone. We celebrate diverse body types, skin tones, ages, and personal style expressions across all our content.
            </p>
          </div>
          <div class="pb-5 border-b border-gray-200">
            <h3 class="text-lg font-light tracking-wide mb-2 text-black">Quality Over Quantity</h3>
            <p class="text-gray-700 font-light leading-relaxed">
              Every article is meticulously researched, beautifully photographed, and edited to meet our high editorial standards.
            </p>
          </div>
          <div>
            <h3 class="text-lg font-light tracking-wide mb-2 text-black">Sustainable Mindset</h3>
            <p class="text-gray-700 font-light leading-relaxed">
              We advocate for conscious fashion choices, promoting quality over consumption and timeless design over disposable trends.
            </p>
          </div>
        </div>
      </section>

      <!-- Disclosure Section -->
      <section class="p-8 md:p-10 bg-gray-50 border border-gray-200">
        <h2 class="text-2xl font-light tracking-wide mb-4 text-black">
          Transparency & Disclosure
        </h2>
        <p class="text-gray-700 font-light leading-relaxed mb-4">
          Fashion Editorial participates in affiliate marketing programs and displays advertising to support content creation. We are transparent about these relationships:
        </p>
        <ul class="space-y-3 text-gray-700 font-light leading-relaxed">
          <li class="flex gap-3">
            <span class="text-gray-500 mt-1">→</span>
            <span>Affiliate links are clearly disclosed in our content</span>
          </li>
          <li class="flex gap-3">
            <span class="text-gray-500 mt-1">→</span>
            <span>All recommendations are honest and unbiased</span>
          </li>
          <li class="flex gap-3">
            <span class="text-gray-500 mt-1">→</span>
            <span>We comply with FTC guidelines and advertising regulations</span>
          </li>
        </ul>
        <p class="text-gray-700 font-light leading-relaxed mt-4">
          For detailed information, please review our <a href="/disclaimer" class="underline hover:text-black transition">Disclaimer</a> and <a href="/privacy-policy" class="underline hover:text-black transition">Privacy Policy</a>.
        </p>
      </section>

      <!-- Get in Touch Section -->
      <section>
        <h2 class="text-3xl md:text-4xl font-light tracking-wide mb-6 text-black">
          Get in Touch
        </h2>
        <p class="text-base md:text-lg text-gray-700 font-light leading-relaxed mb-6">
          Have collaboration ideas, feedback, or just want to say hello? We'd love to hear from you.
        </p>
        <a 
          href="/contact" 
          class="inline-block px-8 py-4 border border-black text-black font-light tracking-wider text-sm hover:bg-black hover:text-white transition-all duration-300"
        >
          CONTACT US
        </a>
      </section>
    </article>
  </main>

  <Footer />
</Layout>
