---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import CompactPostRow from '../../components/CompactPostRow.astro';
import { getAllCategories, getPostsByCategory } from '../../lib/keystatic-reader';

export async function getStaticPaths() {
  const categories = await getAllCategories();
  return categories.map((cat) => ({
    params: { slug: cat.slug },
    props: { category: cat, allCategories: categories },
  }));
}

const { category, allCategories = [] } = Astro.props;
const posts = await getPostsByCategory(category.slug);

// 1. Identify Parent/Child relationships cleanly
const isParentCategory = !category.entry.parentCategory;
const childCategories = allCategories.filter(
  (cat) => cat.entry.parentCategory === category.slug
);

// 👑 VISUAL RHYTHM SEGMENT 1: 45/55 EDITORIAL SPLIT HERO (Latest post inside this scope)
const heroPost = isParentCategory && posts.length > 0 ? posts[0] : null;
const heroSlug = heroPost ? [heroPost.slug] : [];

// 2. Collect child posts mapping while executing zero-duplicate global filtration
const childSections = isParentCategory
  ? await Promise.all(
      childCategories.map(async (child) => {
        const childPosts = await getPostsByCategory(child.slug);
        const filteredChildPosts = childPosts.filter((p) => !heroSlug.includes(p.slug));
        return { childCategory: child, posts: filteredChildPosts };
      })
    )
  : [];

const activeChildSections = childSections.filter((sec) => sec.posts.length > 0);

function resolveImage(img?: string) {
  if (!img) return undefined;
  if (img.startsWith('/')) return img;
  return `/images/posts/${img}`;
}
---

<Layout
  title={`${category.entry.name} — Fashion Editorial`}
  description={category.entry.description || `Explore contemporary styles inside ${category.entry.name}`}
>
  <Header currentPath={`/category/${category.slug}`} />

  <main class="min-h-screen bg-[#faf9f6] text-neutral-900 font-sans antialiased max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    {/* 📋 ARCHIVE TYPE INTROHEADER HEADER */}
    <header class="text-center py-12 md:py-16 border-b border-neutral-200/40">
      <span class="text-[10px] tracking-[0.3em] uppercase text-neutral-400 block mb-2">Category Explore</span>
      <h1 class="text-3xl md:text-5xl font-serif tracking-[0.15em] uppercase text-neutral-950 font-light">
        {category.entry.name}
      </h1>
      {category.entry.description && (
        <p class="text-neutral-500 max-w-xl mx-auto text-xs md:text-sm font-light leading-relaxed pt-2">
          {category.entry.description}
        </p>
      )}
      <div class="w-16 h-[1px] bg-[#bba15c] mx-auto mt-4"></div>
    </header>

    {isParentCategory ? (
      <div class="pb-16">
        
        {/* 👑 VISUAL RHYTHM SEGMENT 1: OPTIMIZED 45/55 EDITORIAL SPLIT HERO */}
        {heroPost && (
          <section class="py-10 md:py-16 border-b border-neutral-200/60">
            <div class="grid grid-cols-1 lg:grid-cols-[45fr_55fr] gap-x-12 gap-y-8 items-center">
              
              {/* Left Side: 45% Space Block (Ideal for 4:5 and 2x2 Collages) */}
              <div class="overflow-hidden w-full aspect-[4/5] bg-neutral-100 rounded-sm relative containment-layout group">
                <a href={`/posts/${heroPost.slug}`} class="block w-full h-full pointer-events-auto">
                  <img
                    src={heroPost.entry.featuredImage?.startsWith('/') ? heroPost.entry.featuredImage : `/images/posts/${heroPost.entry.featuredImage}`}
                    alt={heroPost.entry.title}
                    data-pin-nopin="true"
                    data-pin-nohover="true"
                    loading="eager"
                    fetchpriority="high"
                    class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 block pointer-events-none select-none z-10"
                  />
                </a>
              </div>

              {/* Right Side: 55% Content Frame (Luxury Breathing Text) */}
              <div class="space-y-4 text-left">
                <span class="block text-[10px] font-bold uppercase tracking-[0.3em] text-[#bba15c]">
                  Latest Feature
                </span>
                <a href={`/posts/${heroPost.slug}`} class="block no-underline group">
                  <h2 class="text-2xl sm:text-3xl md:text-4xl font-serif font-light tracking-tight text-neutral-950 leading-tight group-hover:text-neutral-700 transition-colors duration-300 line-clamp-2">
                    {heroPost.entry.title}
                  </h2>
                </a>
                <p class="text-neutral-500 text-sm md:text-base leading-relaxed font-light max-w-xl line-clamp-3">
                  {heroPost.entry.description}
                </p>
                <div class="pt-4">
                  <a href={`/posts/${heroPost.slug}`} class="inline-block text-xs uppercase tracking-widest font-medium border-b border-neutral-950 pb-0.5 hover:text-[#bba15c] hover:border-[#bba15c] transition-colors duration-300 no-underline">
                    Read Article →
                  </a>
                </div>
              </div>

            </div>
          </section>
        )}

        {/* 🎨 CHILD CATEGORIES LOOP WITH THEME INTERCHANGES */}
        {activeChildSections.length > 0 ? (
          activeChildSections.map(({ childCategory, posts: childPosts }, index) => {
            // Index Switches: Pehli child category 2-Columns grid banegi, baki 3-Columns matrices
            const isFirstChild = index === 0;
            const displayPosts = isFirstChild ? childPosts.slice(0, 2) : childPosts.slice(0, 3);

            if (displayPosts.length === 0) return null;

            return (
              <section class="py-12 md:py-16 border-b border-neutral-200/60 last:border-0 dynamic-child-section">
                <div class="text-center mb-10 md:mb-14 space-y-2">
                  <h3 class="text-xs font-serif tracking-[0.3em] uppercase text-neutral-950 font-medium">
                    {childCategory.entry.name}
                  </h3>
                  <div class="w-12 h-[1px] bg-[#bba15c] mx-auto"></div>
                </div>

                {isFirstChild ? (
                  /* 🎭 RHYTHM STYLE A: 2 Large Cards Editorial Grid Layout */
                  <div>
                    <div class="hidden md:grid grid-cols-2 gap-10 max-w-5xl 2xl:max-w-6xl mx-auto">
                      {displayPosts.map((post) => (
                        <a href={`/posts/${post.slug}`} class="block no-underline group space-y-4">
                          <div class="overflow-hidden w-full aspect-[4/5] bg-neutral-100 rounded-sm relative containment-layout">
                            <img
                              src={post.entry.featuredImage?.startsWith('/') ? post.entry.featuredImage : `/images/posts/${post.entry.featuredImage}`}
                              alt={post.entry.title}
                              data-pin-nopin="true"
                              data-pin-nohover="true"
                              loading="lazy"
                              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-102"
                            />
                          </div>
                          <div class="space-y-1.5 text-left">
                            <span class="block text-[10px] font-bold uppercase tracking-widest text-[#bba15c]">
                              {childCategory.entry.name}
                            </span>
                            <h4 class="text-xl font-serif font-light text-neutral-950 leading-tight group-hover:text-neutral-600 transition-colors">
                              {post.entry.title}
                            </h4>
                            <p class="text-neutral-500 text-xs leading-relaxed line-clamp-2 font-light">
                              {post.entry.description}
                            </p>
                          </div>
                        </a>
                      ))}
                    </div>

                    {/* Mobile Anti-Fatigue Split Rows Container */}
                    <div class="block md:hidden space-y-5">
                      {displayPosts.map((post) => (
                        <CompactPostRow
                          title={post.entry.title}
                          slug={post.slug}
                          description={post.entry.description}
                          featuredImage={post.entry.featuredImage}
                          categories={post.entry.categories}
                        />
                      ))}
                    </div>
                  </div>
                ) : (
                  /* 🎭 RHYTHM STYLE B: Uniform 3-Column Grid Block Matrix */
                  <div>
                    <div class="hidden md:grid grid-cols-3 gap-8">
                      {displayPosts.map((post) => (
                        <PostCard
                          title={post.entry.title}
                          slug={post.slug}
                          description={post.entry.description}
                          featuredImage={post.entry.featuredImage}
                          publishedDate={post.entry.publishedDate}
                          categories={post.entry.categories}
                        />
                      ))}
                    </div>

                    {/* Mobile Anti-Fatigue Split Rows Container */}
                    <div class="block md:hidden space-y-5">
                      {displayPosts.map((post) => (
                        <CompactPostRow
                          title={post.entry.title}
                          slug={post.slug}
                          description={post.entry.description}
                          featuredImage={post.entry.featuredImage}
                          categories={post.entry.categories}
                        />
                      ))}
                    </div>
                  </div>
                )}
              </section>
            );
          })
        ) : (
          /* FALLBACK SEGMENT: Executed if Parent Category exists but has zero Child Category trees configured */
          <section class="py-12 md:py-16">
            <div class="hidden md:grid grid-cols-3 gap-8">
              {posts.slice(1).map((post) => (
                <PostCard
                  title={post.entry.title}
                  slug={post.slug}
                  description={post.entry.description}
                  featuredImage={post.entry.featuredImage}
                  publishedDate={post.entry.publishedDate}
                  categories={post.entry.categories}
                />
              ))}
            </div>

            <div class="block md:hidden space-y-5">
              {posts.slice(1).map((post) => (
                <CompactPostRow
                  title={post.entry.title}
                  slug={post.slug}
                  description={post.entry.description}
                  featuredImage={post.entry.featuredImage}
                  categories={post.entry.categories}
                />
              ))}
            </div>
          </section>
        )}

      </div>
    ) : (
      /* 📂 CHILD CATEGORY ARCHIVE DIRECTORY VIEW (Executed if user lands directly on a sub-category leaf) */
      <div class="py-12 md:py-16">
        {posts.length > 0 ? (
          <div>
            <div class="hidden md:grid grid-cols-3 gap-8">
              {posts.map((post) => (
                <PostCard
                  title={post.entry.title}
                  slug={post.slug}
                  description={post.entry.description}
                  featuredImage={resolveImage(post.entry.featuredImage)}
                  publishedDate={post.entry.publishedDate}
                  categories={post.entry.categories}
                />
              ))}
            </div>

            <div class="block md:hidden space-y-5">
              {posts.map((post) => (
                <CompactPostRow
                  title={post.entry.title}
                  slug={post.slug}
                  description={post.entry.description}
                  featuredImage={post.entry.featuredImage}
                  categories={post.entry.categories}
                />
              ))}
            </div>
          </div>
        ) : (
          <div class="text-center py-24 text-neutral-400 font-light text-sm tracking-wide">
            <p>No posts published inside this collection stream yet.</p>
          </div>
        )}
      </div>
    )}
  </main>

  <Footer />
</Layout>

<style is:global>
  .containment-layout {
    contain: paint !important;
  }
</style>
