---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import CompactPostRow from '../../components/CompactPostRow.astro';
import { getAllCategories, getPostsByCategory } from '../../lib/keystatic-reader';

export async function getStaticPaths() {
  const categories = await getAllCategories();
  return categories.map((cat) => ({
    params: { slug: cat.slug },
    props: { category: cat, allCategories: categories },
  }));
}

const { category, allCategories = [] } = Astro.props;
const posts = await getPostsByCategory(category.slug);

// 1. Identify Parent/Child relationships cleanly
const isParentCategory = !category.entry.parentCategory;
const childCategories = allCategories.filter(
  (cat) => cat.entry.parentCategory === category.slug
);

// 👑 SYSTEM UTILITY: Fallback to first image from structures if standalone field doesn't exist
function getPostImage(post: any) {
  if (post.entry.sections && post.entry.sections[0]?.image) return post.entry.sections[0].image;
  if (post.entry.images && post.entry.images[0]) return post.entry.images[0];
  return '/images/placeholder.jpg';
}

// 👑 AUTOMATIC TEXT EXTRACTOR: Strips markdown syntax and slices the first sentences as description overview
async function getPostDescription(post: any, length = 120) {
  const rawContent = await post.entry.content() as string;
  if (!rawContent) return "Explore contemporary style and curated fashion insights inside this editorial.";
  
  const cleanText = rawContent
    .replace(/[#*_`~]/g, '') // Remove formatting characters
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // Keep link text, remove URL formatting
    .replace(/^[-\s]*\n/gm, '') // Remove linebreaks
    .trim();

  return cleanText.length > length ? `${cleanText.substring(0, length)}...` : cleanText;
}

// 👑 VISUAL RHYTHM SEGMENT 1: 45/55 EDITORIAL SPLIT HERO (Latest post inside this scope)
const heroPost = isParentCategory && posts.length > 0 ? posts[0] : null;
const heroSlug = heroPost ? [heroPost.slug] : [];
const heroDesc = heroPost ? await getPostDescription(heroPost, 160) : '';

// 2. Collect child posts mapping while executing zero-duplicate global filtration
const childSections = isParentCategory
  ? await Promise.all(
      childCategories.map(async (child) => {
        const childPosts = await getPostsByCategory(child.slug);
        const filteredChildPosts = childPosts.filter((p) => !heroSlug.includes(p.slug));
        
        // Resolve dynamic descriptions asynchronously inside the nested collection streams
        const childPostsWithDesc = await Promise.all(
          filteredChildPosts.map(async (p) => {
            const desc = await getPostDescription(p, 120);
            return { ...p, dynamicDesc: desc };
          })
        );

        return { childCategory: child, posts: childPostsWithDesc };
      })
    )
  : [];

const activeChildSections = childSections.filter((sec) => sec.posts.length > 0);

// Resolve direct standalone posts with descriptions if user lands on a child category view leaf directly
const directPostsWithDesc = !isParentCategory
  ? await Promise.all(
      posts.map(async (p) => {
        const desc = await getPostDescription(p, 120);
        return { ...p, dynamicDesc: desc };
      })
    )
  : [];
---

<Layout
  title={`${category.entry.name} — Fashion Editorial`}
  description={category.entry.description || `Explore contemporary styles inside ${category.entry.name}`}
>
  <Header currentPath={`/category/${category.slug}`} />

  <main class="min-h-screen bg-[#F8F6F2] text-neutral-900 font-sans antialiased max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    
    {/* 📋 ARCHIVE TYPE INTROHEADER HEADER */}
    <header class="text-center py-10 md:py-14 border-b border-neutral-200/40">
      <span class="text-[10px] tracking-[0.3em] uppercase text-neutral-400 block mb-2">Category Explore</span>
      <h1 class="text-3xl md:text-5xl font-serif tracking-[0.15em] uppercase text-neutral-950 font-light">
        {category.entry.name}
      </h1>
      {category.entry.description && (
        <p class="text-neutral-500 max-w-xl mx-auto text-xs md:text-sm font-light leading-relaxed pt-2">
          {category.entry.description}
        </p>
      )}
      <div class="w-16 h-[1px] bg-[#bba15c] mx-auto mt-4"></div>
    </header>

    {isParentCategory ? (
      <div class="pb-16">
        
        {/* 👑 VISUAL RHYTHM SEGMENT 1: OPTIMIZED 45/55 EDITORIAL SPLIT HERO */}
        {heroPost && (
          <section class="py-12 md:py-16 border-b border-neutral-200/40">
            <div class="grid grid-cols-1 lg:grid-cols-[45fr_55fr] gap-x-12 lg:gap-x-20 gap-y-10 items-center">
              
              <div class="overflow-hidden w-full aspect-[4/5] bg-white p-3 border border-neutral-200/20 shadow-sm/5 rounded-sm relative containment-layout group">
                <a href={`/posts/${heroPost.slug}`} class="block w-full h-full pointer-events-auto">
                  <img
                    src={getPostImage(heroPost)?.startsWith('/') ? getPostImage(heroPost) : `/images/posts/${getPostImage(heroPost)}`}
                    alt={heroPost.entry.title}
                    data-pin-nopin="true"
                    data-pin-nohover="true"
                    loading="eager"
                    fetchpriority="high"
                    class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103 block pointer-events-none select-none z-10"
                  />
                </a>
              </div>

              <div class="space-y-4 text-left lg:pl-2">
                <span class="block text-[10px] font-bold uppercase tracking-[0.3em] text-[#bba15c]">
                  Latest Feature
                </span>
                <a href={`/posts/${heroPost.slug}`} class="block no-underline group">
                  <h2 class="text-2xl sm:text-3xl md:text-4xl font-serif font-light tracking-tight text-neutral-950 leading-tight group-hover:text-neutral-700 transition-colors duration-300 line-clamp-2">
                    {heroPost.entry.title}
                  </h2>
                </a>
                <p class="text-neutral-500 text-sm md:text-[15px] leading-relaxed font-light max-w-xl line-clamp-3">
                  {heroDesc}
                </p>
                <div class="pt-3">
                  <a href={`/posts/${heroPost.slug}`} class="inline-block text-xs uppercase tracking-[0.2em] font-medium border-b border-neutral-950/20 pb-1 text-neutral-950 hover:text-[#bba15c] hover:border-[#bba15c] transition-all duration-300 no-underline group">
                    Read Article <span class="inline-block transition-transform duration-300 group-hover:translate-x-1">→</span>
                  </a>
                </div>
              </div>

            </div>
          </section>
        )}

        {/* 🎨 CHILD CATEGORIES LOOP WITH THEME INTERCHANGES */}
        {activeChildSections.length > 0 ? (
          activeChildSections.map(({ childCategory, posts: childPosts }, index) => {
            const isFirstChild = index === 0;
            const displayPosts = isFirstChild ? childPosts.slice(0, 2) : childPosts.slice(0, 4);

            if (displayPosts.length === 0) return null;

            return (
              <section class="py-14 md:py-20 border-b border-neutral-200/40 last:border-0 dynamic-child-section">
                <div class="text-center mb-12 md:mb-16 space-y-3">
                  <h3 class="text-[11px] font-sans tracking-[0.35em] uppercase text-neutral-950 font-bold">
                    {childCategory.entry.name}
                  </h3>
                  <div class="w-12 h-[1px] bg-[#bba15c] mx-auto"></div>
                </div>

                {isFirstChild ? (
                  /* 🎭 RHYTHM STYLE A: 2 Large Cards Editorial Grid Layout */
                  <div>
                    <div class="hidden md:grid grid-cols-2 gap-10 max-w-5xl 2xl:max-w-6xl mx-auto">
                      {displayPosts.map((post) => (
                        <a href={`/posts/${post.slug}`} class="block no-underline group bg-white p-4 border border-neutral-200/30 shadow-sm/5 transition-all duration-300 hover:shadow-sm rounded-sm space-y-4">
                          <div class="overflow-hidden w-full aspect-[4/5] bg-neutral-100 rounded-[1px] relative containment-layout">
                            <img
                              src={getPostImage(post)?.startsWith('/') ? getPostImage(post) : `/images/posts/${getPostImage(post)}`}
                              alt={post.entry.title}
                              data-pin-nopin="true"
                              data-pin-nohover="true"
                              loading="lazy"
                              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-102"
                            />
                          </div>
                          <div class="space-y-1.5 text-left pt-1">
                            <span class="block text-[9px] font-bold uppercase tracking-[0.2em] text-[#bba15c]">
                              {childCategory.entry.name}
                            </span>
                            <h4 class="text-lg md:text-xl font-serif font-light text-neutral-950 leading-tight group-hover:text-neutral-700 transition-colors">
                              {post.entry.title}
                            </h4>
                            <p class="text-neutral-500 text-xs leading-relaxed line-clamp-2 font-light">
                              {post.dynamicDesc}
                            </p>
                          </div>
                        </a>
                      ))}
                    </div>

                    <div class="block md:hidden space-y-5">
                      {displayPosts.map((post) => (
                        <CompactPostRow
                          title={post.entry.title}
                          slug={post.slug}
                          description={post.dynamicDesc}
                          featuredImage={getPostImage(post)}
                          categories={post.entry.categories}
                        />
                      ))}
                    </div>
                  </div>
                ) : (
                  /* 🎭 RHYTHM STYLE B: Self Balancing Secure Column Grid Framework */
                  <div>
                    <div class={`hidden md:grid gap-8 ${displayPosts.length === 1 ? 'grid-cols-1 max-w-xl mx-auto' : displayPosts.length === 2 ? 'grid-cols-2 max-w-4xl mx-auto' : displayPosts.length === 3 ? 'grid-cols-3 max-w-6xl mx-auto' : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4'}`}>
                      {displayPosts.map((post) => (
                        <PostCard
                          title={post.entry.title}
                          slug={post.slug}
                          description={post.dynamicDesc}
                          featuredImage={getPostImage(post)}
                          publishedDate={post.entry.publishedDate}
                          categories={post.entry.categories}
                        />
                      ))}
                    </div>

                    <div class="block md:hidden space-y-5">
                      {displayPosts.map((post) => (
                        <CompactPostRow
                          title={post.entry.title}
                          slug={post.slug}
                          description={post.dynamicDesc}
                          featuredImage={getPostImage(post)}
                          categories={post.entry.categories}
                        />
                      ))}
                    </div>
                  </div>
                )}
              </section>
            );
          })
        ) : (
          /* FALLBACK SEGMENT */
          <section class="py-12 md:py-16">
            <div class="hidden md:grid grid-cols-3 gap-8">
              {posts.slice(1).map((post) => (
                <PostCard
                  title={post.entry.title}
                  slug={post.slug}
                  description="Explore contemporary style and curated fashion insights inside this editorial."
                  featuredImage={getPostImage(post)}
                  publishedDate={post.entry.publishedDate}
                  categories={post.entry.categories}
                />
              ))}
            </div>
          </section>
        )}

      </div>
    ) : (
      /* 📂 CHILD CATEGORY LEAF STREAM DIRECTORY VIEW */
      <div class="py-12 md:py-16">
        {directPostsWithDesc.length > 0 ? (
          <div>
            <div class="hidden md:grid grid-cols-3 gap-8">
              {directPostsWithDesc.map((post) => (
                <PostCard
                  title={post.entry.title}
                  slug={post.slug}
                  description={post.dynamicDesc}
                  featuredImage={getPostImage(post)}
                  publishedDate={post.entry.publishedDate}
                  categories={post.entry.categories}
                />
              ))}
            </div>

            <div class="block md:hidden space-y-5">
              {directPostsWithDesc.map((post) => (
                <CompactPostRow
                  title={post.entry.title}
                  slug={post.slug}
                  description={post.dynamicDesc}
                  featuredImage={getPostImage(post)}
                  categories={post.entry.categories}
                />
              ))}
            </div>
          </div>
        ) : (
          <div class="text-center py-24 text-neutral-400 font-light text-sm tracking-wide">
            <p>No posts published inside this collection stream yet.</p>
          </div>
        )}
      </div>
    )}
  </main>

  <Footer />
</Layout>

<style is:global>
  .containment-layout {
    contain: paint !important;
  }
</style>
